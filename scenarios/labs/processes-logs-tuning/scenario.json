{
  "id": "processes-logs-tuning",
  "title": "Processes, Logs, Targets, And Tuning",
  "description": "Practice RHCSA v9 process control, persistent logging, systemd targets, and performance tuning.",
  "objective_tags": [
    "processes-logs-tuning"
  ],
  "supported_modes": [
    "lab",
    "exam"
  ],
  "time_limit_minutes": 60,
  "vm_scripts": {
    "clientvm": "scripts/clientvm.sh"
  },
  "flags": {
    "password_recovery": false,
    "requires_servervm": false
  },
  "content": {
    "lab": {
      "tasks": [
        "Identify the CPU-intensive process started by the scenario and lower its CPU priority without stopping it.",
        "Configure the system to preserve the journal across reboots.",
        "Set the tuned profile to throughput-performance and confirm it is active.",
        "Enable and start the rhcsa-note.service unit that writes a stamp file under /var/tmp.",
        "Change the default boot target to multi-user.target."
      ],
      "task_titles": [
        "Busy Process Priority",
        "Persistent Journal",
        "Throughput Performance Profile",
        "Note Service",
        "Default Boot Target"
      ],
      "task_points": [
        10,
        10,
        10,
        10,
        10
      ],
      "solution_commands": [
        [
          "PID=$(pgrep -n -f 'yes >/dev/null')",
          "renice 10 -p \"$PID\""
        ],
        [
          "mkdir -p /var/log/journal",
          "sed -i '/^Storage=/d' /etc/systemd/journald.conf",
          "echo 'Storage=persistent' >> /etc/systemd/journald.conf",
          "systemctl restart systemd-journald"
        ],
        [
          "tuned-adm profile throughput-performance",
          "tuned-adm active"
        ],
        [
          "systemctl enable --now rhcsa-note.service"
        ],
        [
          "systemctl set-default multi-user.target"
        ]
      ],
      "hints": [
        "Use ps, top, renice, or systemctl as needed.",
        "Persistent journaling requires a writable journal directory and journald configuration that keeps logs.",
        "tuned-adm is the expected interface for the tuning task."
      ],
      "checks": [
        "ps -eo pid,ni,comm --sort=ni | head",
        "grep -n '^Storage=' /etc/systemd/journald.conf",
        "tuned-adm active",
        "systemctl status rhcsa-note.service --no-pager",
        "systemctl get-default"
      ],
      "solution_outline": [
        "Renice the seeded busy process rather than killing it.",
        "Enable persistent journaling by creating /var/log/journal and setting journald storage behavior.",
        "Use tuned-adm profile throughput-performance.",
        "Enable and start the custom service and switch the default target with systemctl set-default."
      ]
    },
    "exam": {
      "tasks": [
        "Lower the priority of the seeded CPU-intensive process without stopping it.",
        "Persist the system journal across reboots.",
        "Activate the throughput-performance tuned profile.",
        "Enable and start rhcsa-note.service.",
        "Set the default boot target to multi-user.target."
      ],
      "task_titles": [
        "Busy Process Priority",
        "Persistent Journal",
        "Throughput Performance Profile",
        "Note Service",
        "Default Boot Target"
      ],
      "task_points": [
        10,
        10,
        10,
        10,
        10
      ],
      "solution_commands": [
        [
          "PID=$(pgrep -n -f 'yes >/dev/null')",
          "renice 10 -p \"$PID\""
        ],
        [
          "mkdir -p /var/log/journal",
          "sed -i '/^Storage=/d' /etc/systemd/journald.conf",
          "echo 'Storage=persistent' >> /etc/systemd/journald.conf",
          "systemctl restart systemd-journald"
        ],
        [
          "tuned-adm profile throughput-performance",
          "tuned-adm active"
        ],
        [
          "systemctl enable --now rhcsa-note.service"
        ],
        [
          "systemctl set-default multi-user.target"
        ]
      ]
    }
  }
}
