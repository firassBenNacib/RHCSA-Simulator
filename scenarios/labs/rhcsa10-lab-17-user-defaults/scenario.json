{
  "id": "rhcsa10-lab-17-user-defaults",
  "title": "RHCSA 10 Lab 17: User Defaults",
  "description": "Configure default useradd settings",
  "objective_tags": [
    "users-sudo-ssh"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 20,
  "tracks": [
    "rhcsa10"
  ],
  "rhel_major": 10,
  "flags": {
    "password_recovery": false,
    "requires_server": false
  },
  "content": {
    "lab": {
      "tasks": [
        "Set default inactive password period for new users to 14 days.",
        "Set default account expiration date to 2030-12-31.",
        "Verify the new useradd defaults."
      ],
      "hints": [
        "Use useradd -D.",
        "Defaults must persist in /etc/default/useradd."
      ],
      "checks": [
        "useradd -D | grep -qx 'INACTIVE=14'",
        "useradd -D | grep -qx 'EXPIRE=2030-12-31'",
        "grep -Eq '^INACTIVE=14$' /etc/default/useradd && grep -Eq '^EXPIRE=2030-12-31$' /etc/default/useradd"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "Set default inactive password period for new users to 14 days",
        "Set default account expiration date to 2030-12-31",
        "Verify the new useradd defaults"
      ],
      "task_points": [
        10,
        10,
        10
      ],
      "solution_commands": [
        [
          "useradd -D -f 14"
        ],
        [
          "useradd -D -e 2030-12-31"
        ],
        [
          "useradd -D"
        ]
      ]
    }
  }
}
