{
  "id": "lab-13-grep-filter",
  "title": "Lab 13: Text Filtering With Grep",
  "description": "Extract matching lines from a seeded words file",
  "objective_tags": [
    "essential-tools"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 15,
  "vm_scripts": {
    "clientvm": "scripts/clientvm.sh"
  },
  "flags": {
    "password_recovery": false,
    "requires_servervm": false
  },
  "content": {
    "lab": {
      "tasks": [
        "From /usr/share/dict/words, extract the lines containing ich and save the result to /root/lines."
      ],
      "hints": [
        "The words file for this lab is preseeded if it was not present before."
      ],
      "checks": [
        "test -s /root/lines && grep -q 'ich' /root/lines && ! awk 'index($0,\"ich\")==0{print; exit 1}' /root/lines"
      ],
      "solution_outline": [
        "Use persistent configuration only."
      ],
      "task_titles": [
        "From /usr/share/dict/words, extract the lines..."
      ],
      "task_points": [
        10
      ],
      "solution_commands": [
        [
          "grep \"ich\" /usr/share/dict/words > /root/lines"
        ]
      ]
    }
  }
}
