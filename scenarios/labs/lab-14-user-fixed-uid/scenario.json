    "lab": {
      "tasks": [
        "Create user tavric with UID 4111 and set its password to cinder9."
      ],
      "hints": [
        "Use passwd interactively."
      ],
      "checks": [
        "id tavric"
      ],
      "solution_outline": [
        "Use persistent configuration only."
      ],
      "task_titles": [
        "Part 01"
      ],
      "task_points": [],
      "solution_commands": [
        [
          "useradd -u 4111 tavric",
          "passwd tavric",
          "# enter: cinder9",
          "id tavric"
        ]
      ]
    }
  }
