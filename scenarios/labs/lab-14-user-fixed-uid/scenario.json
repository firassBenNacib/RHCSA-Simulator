{
  "id": "lab-14-user-fixed-uid",
  "title": "Lab 14: User With Fixed UID",
  "description": "Create a local user with a specific UID",
  "objective_tags": [
    "users-sudo-ssh"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 15,
  "tracks": [
    "rhcsa9"
  ],
  "rhel_major": 9,
  "vm_scripts": {
    "client": "scripts/client.sh"
  },
  "flags": {
    "password_recovery": false,
    "requires_server": false
  },
  "content": {
    "lab": {
      "tasks": [
        "Create user tavric with UID 4111 and set its password to cinder9."
      ],
      "hints": [
        "Use passwd interactively."
      ],
      "checks": [
        "id -u tavric | grep -qx '4111' && getent shadow tavric | awk -F: 'length($2)>0 && $2 !~ /^(!!?|\\*|LK|NP)$/' >/dev/null"
      ],
      "solution_outline": [
        "Use persistent configuration only."
      ],
      "task_titles": [
        "Create user tavric with UID 4111 and set its..."
      ],
      "task_points": [
        10
      ],
      "solution_commands": [
        [
          "useradd -u 4111 tavric",
          "passwd tavric",
          "# enter: cinder9",
          "id tavric"
        ]
      ]
    }
  }
}
