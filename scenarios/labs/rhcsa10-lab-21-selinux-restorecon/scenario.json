{
  "id": "rhcsa10-lab-21-selinux-restorecon",
  "title": "RHCSA 10 Lab 21: Restore SELinux Context",
  "description": "Restore default SELinux file contexts",
  "objective_tags": [
    "selinux-and-default-perms"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 20,
  "tracks": [
    "rhcsa10"
  ],
  "rhel_major": 10,
  "flags": {
    "password_recovery": false,
    "requires_server": false
  },
  "content": {
    "lab": {
      "tasks": [
        "Create /var/www/html/rhcsa10.html containing RHCSA10.",
        "Set an incorrect context on the file.",
        "Restore the default context with restorecon."
      ],
      "hints": [
        "Use chcon to simulate a bad label.",
        "Use restorecon to repair the default label."
      ],
      "checks": [
        "test \"$(cat /var/www/html/rhcsa10.html)\" = RHCSA10",
        "matchpathcon /var/www/html/rhcsa10.html | grep -q httpd_sys_content_t",
        "ls -Z /var/www/html/rhcsa10.html | grep -q httpd_sys_content_t"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "Create /var/www/html/rhcsa10.html containing RHCSA10",
        "Set an incorrect context on the file",
        "Restore the default context with restorecon"
      ],
      "task_points": [
        10,
        10,
        10
      ],
      "solution_commands": [
        [
          "echo RHCSA10 > /var/www/html/rhcsa10.html"
        ],
        [
          "chcon -t user_tmp_t /var/www/html/rhcsa10.html"
        ],
        [
          "restorecon -v /var/www/html/rhcsa10.html"
        ]
      ]
    }
  }
}
