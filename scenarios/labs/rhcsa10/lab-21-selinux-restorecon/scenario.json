  },
  "content": {
    "lab": {
      "tasks": [
        "Restore the default SELinux context on /var/www/html/rhcsa10.html."
      ],
      "hints": [
        "Use chcon to simulate a bad label.",
        "Use restorecon to repair the default label."
      ],
      "checks": [
        "test \"$(cat /var/www/html/rhcsa10.html)\" = RHCSA10 && ls -Z /var/www/html/rhcsa10.html | grep -q httpd_sys_content_t"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "Restore the default SELinux context on /var/www/html/rhcsa10.html"
      ],
      "task_points": [
        10
      ],
      "solution_commands": [
        [
          "restorecon -v /var/www/html/rhcsa10.html",
          "ls -Z /var/www/html/rhcsa10.html"
        ]
      ],
      "task_targets": [
        "client"
      ],
      "solution_targets": [
        "client"
      ],
      "check_targets": [
        "client"
      ]
    }
  },
  "vm_scripts": {
    "client": "scripts/client.sh"
  },
