{
  "id": "lab-34-grub-argument",
  "title": "RHCSA 10 Lab 34: Kernel Argument",
  "description": "Persistently modify bootloader kernel arguments",
  "objective_tags": [
    "boot-and-recovery"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 20,
  "tracks": [
    "rhcsa10"
  ],
  "rhel_major": 10,
  "flags": {
    "password_recovery": false,
    "requires_server": false
  },
  "content": {
    "lab": {
      "tasks": [
        "Add kernel argument audit_backlog_limit=8192 persistently and regenerate the GRUB configuration."
      ],
      "hints": [
        "Use grubby --update-kernel=ALL.",
        "Do not rely on a one-time GRUB edit."
      ],
      "checks": [
        "grubby --info=ALL | grep -q 'audit_backlog_limit=8192' && grubby --default-kernel >/dev/null"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "Add kernel argument audit_backlog_limit=8192 persistently and regenerate"
      ],
      "task_points": [
        10
      ],
      "solution_commands": [
        [
          "grubby --update-kernel=ALL --args='audit_backlog_limit=8192'",
          "grub2-mkconfig -o /boot/grub2/grub.cfg"
        ]
      ],
      "task_targets": [
        "client"
      ],
      "solution_targets": [
        "client"
      ],
      "check_targets": [
        "client"
      ]
    }
  },
  "vm_scripts": {
    "client": "scripts/client.sh"
  },
  "scope": "client"
}
