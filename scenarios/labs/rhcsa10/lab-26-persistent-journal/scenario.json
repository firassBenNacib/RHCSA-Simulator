{
  "id": "lab-26-persistent-journal",
  "title": "RHCSA 10 Lab 26: Persistent Journal",
  "description": "Preserve systemd journal logs",
  "objective_tags": [
    "processes-logs-tuning"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 20,
  "tracks": [
    "rhcsa10"
  ],
  "rhel_major": 10,
  "flags": {
    "password_recovery": false,
    "requires_server": false
  },
  "content": {
    "lab": {
      "tasks": [
        "Configure persistent systemd journals.",
        "Restart systemd-journald."
      ],
      "hints": [
        "Create /var/log/journal.",
        "Restart systemd-journald after changing storage."
      ],
      "checks": [
        "test -d /var/log/journal",
        "grep -Eq '^Storage=persistent$' /etc/systemd/journald.conf && systemctl is-active systemd-journald | grep -qx active"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "Configure persistent systemd journals",
        "Restart systemd-journald"
      ],
      "task_points": [
        10,
        10
      ],
      "solution_commands": [
        [
          "mkdir -p /var/log/journal",
          "install -D -m 0644 /dev/null /etc/systemd/journald.conf"
        ],
        [
          "grep -q '^Storage=' /etc/systemd/journald.conf && sed -i 's/^Storage=.*/Storage=persistent/' /etc/systemd/journald.conf || echo 'Storage=persistent' >> /etc/systemd/journald.conf",
          "systemctl restart systemd-journald",
          "journalctl --disk-usage"
        ]
      ]
    }
  },
  "vm_scripts": {
    "client": "scripts/client.sh"
  }
}
