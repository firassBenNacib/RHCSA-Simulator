{
  "id": "lab-24-process-priority",
  "title": "RHCSA 10 Lab 24: Process Priority",
  "description": "Identify and adjust process scheduling",
  "objective_tags": [
    "processes-logs-tuning"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 20,
  "tracks": [
    "rhcsa10"
  ],
  "rhel_major": 10,
  "flags": {
    "password_recovery": false,
    "requires_server": false
  },
  "content": {
    "lab": {
      "tasks": [
        "Start a background sleep process and save its PID in /run/rhcsa10-sleep.pid.",
        "Change the process nice value to 8.",
        "Verify the process priority."
      ],
      "hints": [
        "Use nohup or shell backgrounding.",
        "Use renice against the PID."
      ],
      "checks": [
        "test -s /run/rhcsa10-sleep.pid && kill -0 $(cat /run/rhcsa10-sleep.pid)",
        "ps -o ni= -p $(cat /run/rhcsa10-sleep.pid) | awk '{exit !($1 == 8)}'",
        "kill -0 $(cat /run/rhcsa10-sleep.pid)"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "Start a background sleep process and save its PID in /run/rhcsa10-sleep.",
        "Change the process nice value to 8",
        "Verify the process priority"
      ],
      "task_points": [
        10,
        10,
        10
      ],
      "solution_commands": [
        [
          "sleep 3600 & echo $! > /run/rhcsa10-sleep.pid"
        ],
        [
          "renice -n 8 -p $(cat /run/rhcsa10-sleep.pid)"
        ],
        [
          "ps -o pid,ni,comm -p $(cat /run/rhcsa10-sleep.pid)"
        ]
      ]
    }
  }
}
