{
  "id": "lab-24-process-priority",
  "title": "RHCSA 10 Lab 24: Process Priority",
  "description": "Identify and adjust process scheduling",
  "objective_tags": [
    "processes-logs-tuning"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 20,
  "tracks": [
    "rhcsa10"
  ],
  "rhel_major": 10,
  "flags": {
    "password_recovery": false,
    "requires_server": true
  },
  "content": {
    "lab": {
      "tasks": [
        "On server, start a detached background sleep process and save its PID in /run/rhcsa10-sleep.pid.",
        "On server, change the process nice value to 8."
      ],
      "hints": [
        "Use nohup or shell backgrounding.",
        "Use renice against the PID."
      ],
      "checks": [
        "# server test -s /run/rhcsa10-sleep.pid && kill -0 $(cat /run/rhcsa10-sleep.pid)",
        "# server (ps -o ni= -p $(cat /run/rhcsa10-sleep.pid) | awk '{exit !($1 == 8)}') && (kill -0 $(cat /run/rhcsa10-sleep.pid))"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "Start background process",
        "Change the process nice value to 8"
      ],
      "task_points": [
        10,
        10
      ],
      "solution_commands": [
        [
          "nohup sleep 3600 >/dev/null 2>&1 & echo $! > /run/rhcsa10-sleep.pid",
          "cat /run/rhcsa10-sleep.pid"
        ],
        [
          "renice -n 8 -p $(cat /run/rhcsa10-sleep.pid)",
          "ps -o pid,ni,comm -p $(cat /run/rhcsa10-sleep.pid)"
        ]
      ],
      "task_targets": [
        "server",
        "server"
      ],
      "solution_targets": [
        "server",
        "server"
      ],
      "check_targets": [
        "server",
        "server"
      ]
    }
  },
  "vm_scripts": {
    "client": "scripts/client.sh",
    "server": "scripts/server.sh"
  },
  "scope": "server"
}
