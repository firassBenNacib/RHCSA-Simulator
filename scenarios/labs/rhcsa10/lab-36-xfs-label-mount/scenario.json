{
  "id": "lab-36-xfs-label-mount",
  "title": "RHCSA 10 Lab 36: XFS Label Mount",
  "description": "Create a labeled filesystem and mount persistently",
  "objective_tags": [
    "storage-lvm"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 35,
  "tracks": [
    "rhcsa10"
  ],
  "rhel_major": 10,
  "flags": {
    "password_recovery": false,
    "requires_server": false
  },
  "content": {
    "lab": {
      "tasks": [
        "Create an XFS filesystem on /dev/sdb1 labeled RHCSA10DATA.",
        "Create mount point /mnt/rhcsa10data.",
        "Mount it persistently by label with default options."
      ],
      "hints": [
        "Use mkfs.xfs -L.",
        "Use LABEL= in /etc/fstab."
      ],
      "checks": [
        "blkid /dev/sdb1 | grep -q 'LABEL=\"RHCSA10DATA\"'",
        "test -d /mnt/rhcsa10data",
        "findmnt -no TARGET /mnt/rhcsa10data | grep -qx /mnt/rhcsa10data && grep -Eq '^LABEL=RHCSA10DATA[[:space:]]+/mnt/rhcsa10data[[:space:]]+xfs[[:space:]]+defaults' /etc/fstab"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "Create an XFS filesystem on /dev/sdb1 labeled RHCSA10DATA",
        "Create mount point /mnt/rhcsa10data",
        "Mount it persistently by label with default options"
      ],
      "task_points": [
        10,
        10,
        10
      ],
      "solution_commands": [
        [
          "parted -s /dev/sdb mklabel gpt mkpart primary xfs 1MiB 512MiB",
          "partprobe /dev/sdb || true",
          "udevadm settle",
          "mkfs.xfs -f -L RHCSA10DATA /dev/sdb1"
        ],
        [
          "mkdir -p /mnt/rhcsa10data"
        ],
        [
          "echo 'LABEL=RHCSA10DATA /mnt/rhcsa10data xfs defaults 0 0' >> /etc/fstab",
          "mount -a"
        ]
      ],
      "task_targets": [
        "client",
        "client",
        "client"
      ],
      "solution_targets": [
        "client",
        "client",
        "client"
      ],
      "check_targets": [
        "client",
        "client",
        "client"
      ]
    }
  },
  "vm_scripts": {
    "client": "scripts/client.sh"
  },
  "scope": "client"
}
