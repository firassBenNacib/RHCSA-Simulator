{
  "id": "lab-15-users-groups-sudo",
  "title": "RHCSA 10 Lab 15: Users Groups and Sudo",
  "description": "Create local identities and delegate limited administrative access",
  "objective_tags": [
    "users-sudo-ssh"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 30,
  "tracks": [
    "rhcsa10"
  ],
  "rhel_major": 10,
  "flags": {
    "password_recovery": false,
    "requires_server": false
  },
  "content": {
    "lab": {
      "tasks": [
        "On client, create local group ops10.",
        "On client, create user relay10, set the password to cinder9, and make ops10 the user's supplementary group.",
        "On client, allow members of ops10 to run /usr/bin/systemctl with sudo without a password."
      ],
      "hints": [
        "Use a file under /etc/sudoers.d.",
        "Validate sudoers syntax with visudo -cf."
      ],
      "checks": [
        "getent group ops10 | grep -q '^ops10:'",
        "id -nG relay10 | tr ' ' '\\n' | grep -qx ops10 && getent shadow relay10 | awk -F: 'length($2)>0 && $2 !~ /^(!!?|\\*|LK|NP)$/ {ok=1} END {exit !ok}'",
        "grep -ERq '^%ops10[[:space:]]+ALL=\\(ALL\\)[[:space:]]+NOPASSWD:[[:space:]]*/usr/bin/systemctl$' /etc/sudoers.d && visudo -cf /etc/sudoers >/dev/null"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "Create local group ops10",
        "Create user relay10, set the password to cinder9, and make ops10",
        "Configure sudo access"
      ],
      "task_points": [
        10,
        10,
        10
      ],
      "solution_commands": [
        [
          "getent group ops10 >/dev/null || groupadd ops10",
          "getent group ops10"
        ],
        [
          "id relay10 >/dev/null 2>&1 || useradd -G ops10 relay10",
          "echo 'relay10:cinder9' | chpasswd"
        ],
        [
          "echo '%ops10 ALL=(ALL) NOPASSWD: /usr/bin/systemctl' > /etc/sudoers.d/ops10",
          "chmod 440 /etc/sudoers.d/ops10"
        ]
      ],
      "task_targets": [
        "client",
        "client",
        "client"
      ],
      "solution_targets": [
        "client",
        "client",
        "client"
      ],
      "check_targets": [
        "client",
        "client",
        "client"
      ]
    }
  },
  "vm_scripts": null,
  "scope": "client"
}
