{
  "id": "lab-23-selinux-boolean",
  "title": "RHCSA 10 Lab 23: SELinux Boolean",
  "description": "Set SELinux booleans persistently",
  "objective_tags": [
    "selinux-and-default-perms"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 15,
  "tracks": [
    "rhcsa10"
  ],
  "rhel_major": 10,
  "flags": {
    "password_recovery": false,
    "requires_server": true
  },
  "content": {
    "lab": {
      "tasks": [
        "On server, enable the httpd_can_network_connect SELinux boolean immediately.",
        "On server, make the httpd_can_network_connect SELinux boolean persistent."
      ],
      "hints": [
        "Use setsebool -P.",
        "Use getsebool for verification."
      ],
      "checks": [
        "# server getsebool httpd_can_network_connect | grep -Eq -- '--> on$'",
        "# server semanage boolean -l -C | grep -E '^httpd_can_network_connect\\s+\\(on\\s*,\\s*on\\)'"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "enable the httpd_can_network_connect SELinux boolean immediately",
        "make the httpd_can_network_connect SELinux boolean persistent"
      ],
      "task_points": [
        10,
        10
      ],
      "solution_commands": [
        [
          "setsebool httpd_can_network_connect on"
        ],
        [
          "setsebool -P httpd_can_network_connect on",
          "semanage boolean -l | grep httpd_can_network_connect"
        ]
      ]
    }
  },
  "vm_scripts": {
    "client": "scripts/client.sh"
  },
  "scope": "server"
}
