{
  "id": "lab-19-firewalld-service",
  "title": "RHCSA 10 Lab 19: Firewalld Service",
  "description": "Manage persistent firewalld service rules",
  "objective_tags": [
    "networking-and-firewall",
    "selinux-and-default-perms"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 20,
  "tracks": [
    "rhcsa10"
  ],
  "rhel_major": 10,
  "flags": {
    "password_recovery": false,
    "requires_server": true
  },
  "content": {
    "lab": {
      "tasks": [
        "On server, ensure firewalld is enabled and running.",
        "On server, permanently allow the https service in the public zone.",
        "On server, reload firewalld and verify the service is allowed."
      ],
      "hints": [
        "Use --permanent for persistent rules.",
        "Reload after changing permanent configuration."
      ],
      "checks": [
        "# server systemctl is-enabled firewalld | grep -qx enabled && systemctl is-active firewalld | grep -qx active",
        "# server firewall-cmd --permanent --zone=public --query-service=https",
        "# server firewall-cmd --zone=public --query-service=https"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "Ensure firewalld is enabled and running",
        "Permanently allow the https service in the public zone",
        "Reload firewalld and verify the service is allowed"
      ],
      "task_points": [
        10,
        10,
        10
      ],
      "solution_commands": [
        [
          "systemctl enable --now firewalld"
        ],
        [
          "firewall-cmd --permanent --zone=public --add-service=https"
        ],
        [
          "firewall-cmd --reload",
          "firewall-cmd --zone=public --list-services"
        ]
      ],
      "task_targets": [
        "server",
        "server",
        "server"
      ],
      "solution_targets": [
        "server",
        "server",
        "server"
      ],
      "check_targets": [
        "server",
        "server",
        "server"
      ]
    }
  },
  "vm_scripts": {
    "client": "scripts/client.sh"
  },
  "scope": "server"
}
