{
  "id": "lab-30-systemd-service",
  "title": "RHCSA 10 Lab 30: Custom Service",
  "description": "Create and enable a custom systemd service",
  "objective_tags": [
    "software-scheduling-time"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 25,
  "tracks": [
    "rhcsa10"
  ],
  "rhel_major": 10,
  "flags": {
    "password_recovery": false,
    "requires_server": true
  },
  "content": {
    "lab": {
      "tasks": [
        "On server, create /usr/local/sbin/rhcsa10-service.sh that writes SERVICE10 to /var/tmp/rhcsa10-service.out.",
        "On server, create a oneshot service named rhcsa10-service.service that runs the script.",
        "On server, enable and start the service."
      ],
      "hints": [
        "Use Type=oneshot.",
        "Reload systemd before enabling a new unit."
      ],
      "checks": [
        "# server test -x /usr/local/sbin/rhcsa10-service.sh",
        "# server test -f /etc/systemd/system/rhcsa10-service.service && grep -Fqx 'ExecStart=/usr/local/sbin/rhcsa10-service.sh' /etc/systemd/system/rhcsa10-service.service",
        "# server systemctl is-enabled rhcsa10-service.service | grep -qx enabled && grep -qx SERVICE10 /var/tmp/rhcsa10-service.out"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "Create /usr/local/sbin/rhcsa10-service.sh that writes SERVICE10 to /var/",
        "Create a oneshot service named rhcsa10-service.service that runs the scr",
        "Enable and start the service"
      ],
      "task_points": [
        10,
        10,
        10
      ],
      "solution_commands": [
        [
          "cat > /usr/local/sbin/rhcsa10-service.sh <<'EOF'",
          "#!/bin/bash",
          "echo SERVICE10 > /var/tmp/rhcsa10-service.out",
          "EOF",
          "chmod +x /usr/local/sbin/rhcsa10-service.sh"
        ],
        [
          "cat > /etc/systemd/system/rhcsa10-service.service <<'EOF'",
          "[Unit]",
          "Description=RHCSA10 oneshot service",
          "",
          "[Service]",
          "Type=oneshot",
          "ExecStart=/usr/local/sbin/rhcsa10-service.sh",
          "",
          "[Install]",
          "WantedBy=multi-user.target",
          "EOF"
        ],
        [
          "restorecon -v /usr/local/sbin/rhcsa10-service.sh /etc/systemd/system/rhcsa10-service.service || true",
          "systemctl daemon-reload",
          "systemctl enable --now rhcsa10-service.service"
        ]
      ],
      "task_targets": [
        "server",
        "server",
        "server"
      ],
      "solution_targets": [
        "server",
        "server",
        "server"
      ],
      "check_targets": [
        "server",
        "server",
        "server"
      ]
    }
  },
  "vm_scripts": {
    "server": "scripts/server.sh"
  },
  "scope": "server"
}
