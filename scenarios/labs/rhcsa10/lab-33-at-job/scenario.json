{
  "id": "lab-33-at-job",
  "title": "RHCSA 10 Lab 33: At Job",
  "description": "Schedule one-time tasks with at",
  "objective_tags": [
    "software-scheduling-time"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 20,
  "tracks": [
    "rhcsa10"
  ],
  "rhel_major": 10,
  "flags": {
    "password_recovery": false,
    "requires_server": true
  },
  "content": {
    "lab": {
      "tasks": [
        "On server, create user at10 and set password cinder9.",
        "On server, enable and start atd.",
        "On server, as at10, schedule a job that appends AT10 to /home/at10/at10.log two minutes from now."
      ],
      "hints": [
        "Use standard input to submit the at job.",
        "Use atq to verify a queued job."
      ],
      "checks": [
        "# server getent passwd at10 >/dev/null",
        "# server systemctl is-enabled atd | grep -qx enabled && systemctl is-active atd | grep -qx active",
        "# server atq | grep -q at10"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "Create user at10 and set password cinder9",
        "Enable and start atd",
        "As at10, schedule a job that appends AT10 to /home/at10/at10.log two min"
      ],
      "task_points": [
        10,
        10,
        10
      ],
      "solution_commands": [
        [
          "useradd at10",
          "passwd at10",
          "# enter: cinder9"
        ],
        [
          "systemctl enable --now atd"
        ],
        [
          "su - at10",
          "echo 'echo AT10 >> /home/at10/at10.log' | at now + 2 minutes",
          "atq"
        ]
      ],
      "task_targets": [
        "server",
        "server",
        "server"
      ],
      "solution_targets": [
        "server",
        "server",
        "server"
      ],
      "check_targets": [
        "server",
        "server",
        "server"
      ]
    }
  },
  "vm_scripts": {
    "client": "scripts/client.sh",
    "server": "scripts/server.sh"
  },
  "scope": "server"
}
