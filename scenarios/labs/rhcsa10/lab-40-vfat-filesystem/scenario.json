{
  "id": "lab-40-vfat-filesystem",
  "title": "RHCSA 10 Lab 40: VFAT Filesystem",
  "description": "Create and mount a VFAT filesystem",
  "objective_tags": [
    "storage-lvm"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 25,
  "tracks": [
    "rhcsa10"
  ],
  "rhel_major": 10,
  "flags": {
    "password_recovery": false,
    "requires_server": false
  },
  "content": {
    "lab": {
      "tasks": [
        "Create a 256 MiB partition on /dev/sdb.",
        "Format it as VFAT with label RHCSA10VFAT.",
        "Mount it persistently at /mnt/vfat10."
      ],
      "hints": [
        "Use mkfs.vfat -n.",
        "Use vfat in /etc/fstab."
      ],
      "checks": [
        "parted -sm /dev/sdb unit MiB print | awk -F: '$1 == \"1\" && int($4) >= 250 && int($4) <= 260 {ok=1} END {exit !ok}'",
        "blkid /dev/sdb1 | grep -q 'TYPE=\"vfat\"' && blkid /dev/sdb1 | grep -q 'LABEL_FATBOOT=\"RHCSA10VFAT\"\\|LABEL=\"RHCSA10VFAT\"'",
        "findmnt -no TARGET /mnt/vfat10 | grep -qx /mnt/vfat10 && grep -Eq '^LABEL=RHCSA10VFAT[[:space:]]+/mnt/vfat10[[:space:]]+vfat' /etc/fstab"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "Create a 256 MiB partition on /dev/sdb",
        "Format it as VFAT with label RHCSA10VFAT",
        "Mount it persistently at /mnt/vfat10"
      ],
      "task_points": [
        10,
        10,
        10
      ],
      "solution_commands": [
        [
          "wipefs -a /dev/sdb >/dev/null 2>&1 || true",
          "sgdisk --zap-all /dev/sdb >/dev/null 2>&1 || true",
          "parted -s /dev/sdb mklabel gpt mkpart primary fat32 1MiB 257MiB",
          "partprobe /dev/sdb || true",
          "udevadm settle"
        ],
        [
          "mkfs.vfat -F 32 -n RHCSA10VFAT /dev/sdb1"
        ],
        [
          "mkdir -p /mnt/vfat10",
          "echo 'LABEL=RHCSA10VFAT /mnt/vfat10 vfat defaults 0 0' >> /etc/fstab",
          "mount -a"
        ]
      ],
      "task_targets": [
        "client",
        "client",
        "client"
      ],
      "solution_targets": [
        "client",
        "client",
        "client"
      ],
      "check_targets": [
        "client",
        "client",
        "client"
      ]
    }
  },
  "vm_scripts": {
    "client": "scripts/client.sh"
  },
  "scope": "client"
}
