{
  "id": "lab-46-package-file-install",
  "title": "RHCSA 10 Lab 46: Local RPM Install",
  "description": "Install software from a local RPM file",
  "objective_tags": [
    "software-management"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 20,
  "tracks": [
    "rhcsa10"
  ],
  "rhel_major": 10,
  "flags": {
    "password_recovery": false,
    "requires_server": true
  },
  "content": {
    "lab": {
      "tasks": [
        "On client, install the local tree RPM from /var/www/html/repo or the mounted ISO without enabling external repositories.",
        "On server, install the tree package from the local repositories."
      ],
      "hints": [
        "Use find to locate tree*.rpm.",
        "Use dnf install /path/to/package.rpm."
      ],
      "checks": [
        "command -v tree >/dev/null && rpm -q tree >/dev/null",
        "# server command -v tree >/dev/null && rpm -q tree >/dev/null"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "Install the local tree RPM from /var/www/html/repo or the mounted ISO",
        "Install the tree package from the local repositories"
      ],
      "task_points": [
        10,
        10
      ],
      "solution_commands": [
        [
          "dnf install -y --disablerepo='*' --enablerepo=rhcsa-baseos --enablerepo=rhcsa-appstream tree",
          "rpm -q tree"
        ],
        [
          "# On server",
          "dnf install -y tree",
          "rpm -q tree"
        ]
      ],
      "task_targets": [
        "client",
        "server"
      ],
      "solution_targets": [
        "client",
        "server"
      ],
      "check_targets": [
        "client",
        "server"
      ]
    }
  },
  "vm_scripts": {
    "client": "scripts/client.sh",
    "server": "scripts/server.sh"
  },
  "scope": "client-server"
}
