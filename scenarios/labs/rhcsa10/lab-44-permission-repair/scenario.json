{
  "id": "lab-44-permission-repair",
  "title": "RHCSA 10 Lab 44: Permission Repair",
  "description": "Diagnose and repair file permission problems",
  "objective_tags": [
    "selinux-and-default-perms"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 20,
  "tracks": [
    "rhcsa10"
  ],
  "rhel_major": 10,
  "flags": {
    "password_recovery": false,
    "requires_server": true
  },
  "content": {
    "lab": {
      "tasks": [
        "On server, create /srv/repair10/report.txt.",
        "On server, make the file readable and writable by owner and group, and unreadable by others.",
        "On server, ensure the parent directory allows group traversal."
      ],
      "hints": [
        "Use chmod 660 for the file.",
        "Use chmod 770 for the directory."
      ],
      "checks": [
        "# server test -f /srv/repair10/report.txt",
        "# server stat -c '%a' /srv/repair10/report.txt | grep -qx 660",
        "# server stat -c '%a' /srv/repair10 | grep -qx 770"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "create /srv/repair10/report.txt",
        "make the file readable and writable by owner and group, and unreadable b",
        "ensure the parent directory allows group traversal"
      ],
      "task_points": [
        10,
        10,
        10
      ],
      "solution_commands": [
        [
          "mkdir -p /srv/repair10",
          "touch /srv/repair10/report.txt"
        ],
        [
          "chmod 660 /srv/repair10/report.txt"
        ],
        [
          "chmod 770 /srv/repair10"
        ]
      ]
    }
  },
  "vm_scripts": null,
  "scope": "server"
}
