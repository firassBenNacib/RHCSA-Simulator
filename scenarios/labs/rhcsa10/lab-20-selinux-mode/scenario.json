{
  "id": "lab-20-selinux-mode",
  "title": "RHCSA 10 Lab 20: SELinux Mode",
  "description": "Set SELinux enforcing mode persistently",
  "objective_tags": [
    "selinux-and-default-perms"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 20,
  "tracks": [
    "rhcsa10"
  ],
  "rhel_major": 10,
  "flags": {
    "password_recovery": false,
    "requires_server": false
  },
  "content": {
    "lab": {
      "tasks": [
        "Set SELinux to enforcing mode immediately.",
        "Configure SELinux to boot in enforcing mode."
      ],
      "hints": [
        "Use setenforce for runtime state.",
        "Edit /etc/selinux/config for persistence."
      ],
      "checks": [
        "getenforce | grep -qx Enforcing",
        "(grep -Eq '^SELINUX=enforcing$' /etc/selinux/config) && (sestatus | grep -q 'Current mode')"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "Set SELinux to enforcing mode immediately",
        "Configure SELinux to boot in enforcing mode"
      ],
      "task_points": [
        10,
        20
      ],
      "solution_commands": [
        [
          "setenforce 1"
        ],
        [
          "sed -i 's/^SELINUX=.*/SELINUX=enforcing/' /etc/selinux/config",
          "getenforce",
          "grep '^SELINUX=' /etc/selinux/config"
        ]
      ]
    }
  },
  "vm_scripts": {
    "client": "scripts/client.sh"
  }
}
