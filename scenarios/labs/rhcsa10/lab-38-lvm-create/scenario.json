{
  "id": "lab-38-lvm-create",
  "title": "RHCSA 10 Lab 38: LVM Create",
  "description": "Create and mount a logical volume",
  "objective_tags": [
    "storage-lvm"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 40,
  "tracks": [
    "rhcsa10"
  ],
  "rhel_major": 10,
  "flags": {
    "password_recovery": false,
    "requires_server": false
  },
  "content": {
    "lab": {
      "tasks": [
        "Create physical volume /dev/sdb.",
        "Create volume group vg10.",
        "Create a 384 MiB logical volume lvdata formatted with XFS and mounted at /mnt/lvdata10 persistently."
      ],
      "hints": [
        "Use pvcreate, vgcreate, and lvcreate.",
        "Add the logical volume to /etc/fstab."
      ],
      "checks": [
        "pvs /dev/sdb >/dev/null",
        "vgs vg10 >/dev/null",
        "lvs /dev/vg10/lvdata >/dev/null && findmnt -no TARGET /mnt/lvdata10 | grep -qx /mnt/lvdata10 && grep -Eq '/dev/vg10/lvdata[[:space:]]+/mnt/lvdata10[[:space:]]+xfs' /etc/fstab"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "Create physical volume /dev/sdb",
        "Create volume group",
        "Configure LVM storage"
      ],
      "task_points": [
        10,
        10,
        10
      ],
      "solution_commands": [
        [
          "wipefs -a /dev/sdb >/dev/null 2>&1 || true",
          "sgdisk --zap-all /dev/sdb >/dev/null 2>&1 || true",
          "pvcreate -ff -y /dev/sdb"
        ],
        [
          "vgcreate vg10 /dev/sdb"
        ],
        [
          "lvcreate -L 384M -n lvdata vg10",
          "mkfs.xfs -f /dev/vg10/lvdata",
          "mkdir -p /mnt/lvdata10",
          "echo '/dev/vg10/lvdata /mnt/lvdata10 xfs defaults 0 0' >> /etc/fstab",
          "mount -a"
        ]
      ],
      "task_targets": [
        "client",
        "client",
        "client"
      ],
      "solution_targets": [
        "client",
        "client",
        "client"
      ],
      "check_targets": [
        "client",
        "client",
        "client"
      ]
    }
  },
  "vm_scripts": {
    "client": "scripts/client.sh"
  },
  "scope": "client"
}
