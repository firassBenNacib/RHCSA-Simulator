{
  "id": "lab-27-rsyslog-logger",
  "title": "RHCSA 10 Lab 27: Rsyslog Logger",
  "description": "Create and route log messages",
  "objective_tags": [
    "processes-logs-tuning"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 20,
  "tracks": [
    "rhcsa10"
  ],
  "rhel_major": 10,
  "flags": {
    "password_recovery": false,
    "requires_server": true
  },
  "content": {
    "lab": {
      "tasks": [
        "On server, ensure rsyslog is running.",
        "On server, configure local7.* messages to log to /var/log/rhcsa10-local7.log.",
        "On server, send a logger test message with facility local7 and verify it is written."
      ],
      "hints": [
        "Use a file under /etc/rsyslog.d.",
        "Use logger -p local7.info."
      ],
      "checks": [
        "# server systemctl is-active rsyslog | grep -qx active",
        "# server grep -Rqx 'local7.* /var/log/rhcsa10-local7.log' /etc/rsyslog.d",
        "# server grep -q 'RHCSA10 local7 test' /var/log/rhcsa10-local7.log"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "ensure rsyslog is running",
        "configure local7.* messages to log to /var/log/rhcsa10-local7.log",
        "send a logger test message with facility local7 and verify it is written"
      ],
      "task_points": [
        10,
        10,
        10
      ],
      "solution_commands": [
        [
          "systemctl enable --now rsyslog"
        ],
        [
          "echo 'local7.* /var/log/rhcsa10-local7.log' > /etc/rsyslog.d/rhcsa10.conf",
          "systemctl restart rsyslog"
        ],
        [
          "logger -p local7.info 'RHCSA10 local7 test'",
          "sleep 1",
          "grep 'RHCSA10 local7 test' /var/log/rhcsa10-local7.log"
        ]
      ]
    }
  },
  "vm_scripts": {
    "client": "scripts/client.sh"
  },
  "scope": "server"
}
