{
  "id": "lab-05-rpm-packages",
  "title": "RHCSA 10 Lab 05: RPM Packages",
  "description": "Install and remove RPM software",
  "objective_tags": [
    "software-management"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 20,
  "tracks": [
