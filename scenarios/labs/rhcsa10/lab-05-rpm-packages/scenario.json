  "rhel_major": 10,
  "flags": {
    "password_recovery": false,
    "requires_server": true
  },
  "content": {
    "lab": {
      "tasks": [
        "Install the lsof package.",
        "Remove the tcpdump package if it is installed."
      ],
      "hints": [
        "Use dnf for package changes.",
        "Use rpm -q for final verification."
      ],
      "checks": [
        "rpm -q lsof >/dev/null",
        "(! rpm -q tcpdump >/dev/null 2>&1) && (rpm -q lsof >/dev/null && ! rpm -q tcpdump >/dev/null 2>&1)"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "Install the lsof package",
        "Remove the tcpdump package if it is installed"
      ],
      "task_points": [
        10,
        20
      ],
      "solution_commands": [
        [
          "dnf install -y lsof"
        ],
        [
          "dnf remove -y tcpdump",
          "rpm -q lsof",
          "rpm -q tcpdump || true"
        ]
      ],
      "task_targets": [
        "client",
        "client"
      ],
      "solution_targets": [
        "client",
        "client"
      ],
      "check_targets": [
        "client",
        "client"
      ]
    }
  },
  "vm_scripts": {
    "client": "scripts/client.sh"
  },
  "scope": "client-server"
}
