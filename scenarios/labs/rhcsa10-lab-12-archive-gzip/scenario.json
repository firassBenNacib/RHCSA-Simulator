      "checks": [
        "test -f /root/rhcsa10-etc.tar.gz",
        "file /root/rhcsa10-etc.tar.gz | grep -qi gzip",
        "tar -tzf /root/rhcsa10-etc.tar.gz | grep -Eq 'etc/(hosts|fstab)'"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "Create /root/rhcsa10-etc.tar.gz containing /etc/hosts and /etc/fstab",
