{
  "id": "filesystems-and-autofs",
  "title": "Filesystems, NFS, And Autofs",
  "description": "Practice RHCSA v9 persistent network mounts and indirect automount maps against the reusable server infrastructure.",
  "objective_tags": [
    "filesystems-and-autofs"
  ],
  "supported_modes": [
    "lab",
    "exam"
  ],
  "time_limit_minutes": 60,
  "vm_scripts": {
    "servervm": "scripts/servervm.sh",
    "clientvm": "scripts/clientvm.sh"
  },
  "flags": {
    "password_recovery": false,
    "requires_servervm": true
  },
  "content": {
    "lab": {
      "tasks": [
        "Create a persistent NFS mount on clientvm for servervm:/exports/direct at /mnt/direct-share.",
        "Configure autofs so /projects/readme resolves to the README file exported from servervm:/exports/autofs/projects.",
        "Ensure autofs starts automatically and verify the indirect map works on demand."
      ],
      "task_titles": [
        "Persistent NFS Mount",
        "Autofs Indirect Map",
        "Autofs Verification"
      ],
      "task_points": [
        15,
        15,
        10
      ],
      "solution_commands": [
        [
          "mkdir -p /mnt/direct-share",
          "grep -q '^servervm:/exports/direct /mnt/direct-share ' /etc/fstab || echo 'servervm:/exports/direct /mnt/direct-share nfs defaults,_netdev 0 0' >> /etc/fstab",
          "mount /mnt/direct-share"
        ],
        [
          "mkdir -p /projects",
          "cat > /etc/auto.rhcsa <<'EOF'",
          "readme -fstype=nfs servervm:/exports/autofs/projects",
          "EOF",
          "cat > /etc/auto.master.d/rhcsa.autofs <<'EOF'",
          "/projects /etc/auto.rhcsa",
          "EOF"
        ],
        [
          "systemctl enable --now autofs",
          "ls -l /projects/readme"
        ]
      ],
      "hints": [
        "The direct mount belongs in /etc/fstab.",
        "The autofs task needs both an auto.master entry and a map file.",
        "Use showmount -e servervm if you need to confirm exports."
      ],
      "checks": [
        "findmnt /mnt/direct-share",
        "systemctl status autofs --no-pager",
        "ls -l /projects/readme"
      ],
      "solution_outline": [
        "Create the persistent NFS entry in /etc/fstab and mount it.",
        "Use an indirect map under /projects that points readme to the exported path on servervm.",
        "Enable autofs and verify the on-demand mount after access."
      ]
    },
    "exam": {
      "tasks": [
        "Create a persistent NFS mount for servervm:/exports/direct at /mnt/direct-share.",
        "Configure autofs so /projects/readme resolves from servervm:/exports/autofs/projects.",
        "Enable autofs and verify the map works on demand."
      ],
      "task_titles": [
        "Persistent NFS Mount",
        "Autofs Indirect Map",
        "Autofs Verification"
      ],
      "task_points": [
        15,
        15,
        10
      ],
      "solution_commands": [
        [
          "mkdir -p /mnt/direct-share",
          "grep -q '^servervm:/exports/direct /mnt/direct-share ' /etc/fstab || echo 'servervm:/exports/direct /mnt/direct-share nfs defaults,_netdev 0 0' >> /etc/fstab",
          "mount /mnt/direct-share"
        ],
        [
          "mkdir -p /projects",
          "cat > /etc/auto.rhcsa <<'EOF'",
          "readme -fstype=nfs servervm:/exports/autofs/projects",
          "EOF",
          "cat > /etc/auto.master.d/rhcsa.autofs <<'EOF'",
          "/projects /etc/auto.rhcsa",
          "EOF"
        ],
        [
          "systemctl enable --now autofs",
          "ls -l /projects/readme"
        ]
      ]
    }
  }
}
