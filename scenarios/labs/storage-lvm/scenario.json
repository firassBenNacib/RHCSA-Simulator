{
  "id": "storage-lvm",
  "title": "Local Storage And LVM",
  "description": "Practice RHCSA v9 partitioning, LVM creation, swap, and persistent filesystem mounts on the attached data disks.",
  "objective_tags": [
    "storage-lvm"
  ],
  "supported_modes": [
    "lab",
    "exam"
  ],
  "time_limit_minutes": 60,
  "vm_scripts": {
    "clientvm": "scripts/clientvm.sh"
  },
  "flags": {
    "password_recovery": false,
    "requires_servervm": false
  },
  "content": {
    "lab": {
      "tasks": [
        "Use the attached data disks to create a volume group named rhcsa_vg and a logical volume named labdata sized to 512 MiB.",
        "Format labdata with XFS and mount it persistently at /srv/labdata.",
        "Create an additional 256 MiB swap logical volume named labswap and activate it persistently.",
        "Create a separate 300 MiB ext4 filesystem on remaining space and mount it persistently at /mnt/labext4.",
        "Ensure all new storage survives reboot."
      ],
      "task_titles": [
        "Volume Group And labdata LV",
        "XFS Data Mount",
        "Swap Logical Volume",
        "ext4 Filesystem Mount",
        "Reboot Persistence Check"
      ],
      "task_points": [
        10,
        15,
        10,
        10,
        5
      ],
      "solution_commands": [
        [
          "pvcreate /dev/sdb /dev/sdc",
          "vgcreate rhcsa_vg /dev/sdb /dev/sdc",
          "lvcreate -L 512M -n labdata rhcsa_vg"
        ],
        [
          "mkfs.xfs /dev/rhcsa_vg/labdata",
          "mkdir -p /srv/labdata",
          "echo '/dev/rhcsa_vg/labdata /srv/labdata xfs defaults 0 0' >> /etc/fstab",
          "mount /srv/labdata"
        ],
        [
          "lvcreate -L 256M -n labswap rhcsa_vg",
          "mkswap /dev/rhcsa_vg/labswap",
          "echo '/dev/rhcsa_vg/labswap none swap defaults 0 0' >> /etc/fstab",
          "swapon -a"
        ],
        [
          "lvcreate -L 300M -n labext4 rhcsa_vg",
          "mkfs.ext4 /dev/rhcsa_vg/labext4",
          "mkdir -p /mnt/labext4",
          "echo '/dev/rhcsa_vg/labext4 /mnt/labext4 ext4 defaults 0 0' >> /etc/fstab",
          "mount /mnt/labext4"
        ],
        [
          "findmnt /srv/labdata",
          "findmnt /mnt/labext4",
          "swapon --show"
        ]
      ],
      "hints": [
        "Use lsblk first to identify the two attached data disks.",
        "You can use one or both disks as physical volumes.",
        "Use /etc/fstab entries by UUID or device mapper path for persistence."
      ],
      "checks": [
        "pvs",
        "vgs",
        "lvs",
        "findmnt /srv/labdata",
        "findmnt /mnt/labext4",
        "swapon --show"
      ],
      "solution_outline": [
        "Create physical volumes, create rhcsa_vg, then create labdata and labswap logical volumes.",
        "Format the data filesystems with mkfs.xfs and mkfs.ext4 as required.",
        "Persist the mounts and swap activation in /etc/fstab."
      ]
    },
    "exam": {
      "tasks": [
        "Create volume group rhcsa_vg on the attached data disks.",
        "Create and mount an XFS logical volume labdata at /srv/labdata.",
        "Create and activate a 256 MiB swap logical volume named labswap.",
        "Create and mount a persistent ext4 filesystem at /mnt/labext4."
      ],
      "task_titles": [
        "Volume Group And labdata LV",
        "XFS Data Mount",
        "Swap Logical Volume",
        "ext4 Filesystem Mount"
      ],
      "task_points": [
        25,
        30,
        20,
        25
      ],
      "solution_commands": [
        [
          "pvcreate /dev/sdb /dev/sdc",
          "vgcreate rhcsa_vg /dev/sdb /dev/sdc",
          "lvcreate -L 512M -n labdata rhcsa_vg"
        ],
        [
          "mkfs.xfs /dev/rhcsa_vg/labdata",
          "mkdir -p /srv/labdata",
          "echo '/dev/rhcsa_vg/labdata /srv/labdata xfs defaults 0 0' >> /etc/fstab",
          "mount /srv/labdata"
        ],
        [
          "lvcreate -L 256M -n labswap rhcsa_vg",
          "mkswap /dev/rhcsa_vg/labswap",
          "echo '/dev/rhcsa_vg/labswap none swap defaults 0 0' >> /etc/fstab",
          "swapon -a"
        ],
        [
          "lvcreate -L 300M -n labext4 rhcsa_vg",
          "mkfs.ext4 /dev/rhcsa_vg/labext4",
          "mkdir -p /mnt/labext4",
          "echo '/dev/rhcsa_vg/labext4 /mnt/labext4 ext4 defaults 0 0' >> /etc/fstab",
          "mount /mnt/labext4"
        ]
      ]
    }
  }
}
