{
  "id": "lab-44-filesystem-label-mount",
  "title": "Lab 44: Filesystem By Label",
  "description": "Create a filesystem, label it, and mount it persistently by label",
  "objective_tags": [
    "storage-lvm"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 25,
  "vm_scripts": {
    "clientvm": "scripts/clientvm.sh"
  },
  "flags": {
    "password_recovery": false,
    "requires_servervm": false
  },
  "content": {
    "lab": {
      "tasks": [
        "On /dev/sdb, create a GPT partition of 600 MiB for an ext4 filesystem.",
        "Format the new partition with the filesystem label DATA44 and mount it at /data44.",
        "Configure the mount persistently in /etc/fstab by using LABEL=DATA44."
      ],
      "hints": [
        "Use blkid or lsblk -f to verify the label."
      ],
      "checks": [
        "blkid /dev/sdb1",
        "findmnt /data44"
      ],
      "solution_outline": [],
      "task_titles": [],
      "task_points": [],
      "solution_commands": [
        [
          "fdisk /dev/sdb",
          "# g",
          "# n",
          "# <Enter>",
          "# <Enter>",
          "# +600M",
          "# w"
        ],
        [
          "mkfs.ext4 -L DATA44 /dev/sdb1",
          "mkdir -p /data44"
        ],
        [
          "vim /etc/fstab",
          "LABEL=DATA44 /data44 ext4 defaults 0 0",
          ":wq",
          "mount -a",
          "findmnt /data44"
        ]
      ]
    }
  }
}
