  },
  "content": {
    "lab": {
      "tasks": [
        "Apply the recommended tuned profile and leave it active after reboot."
      ],
      "hints": [
        "Use tuned-adm recommended to see the target profile."
      ],
      "checks": [
        "tuned-adm active",
        "tuned-adm recommended"
      ],
      "solution_outline": [
        "Use persistent configuration only."
      ],
      "task_titles": [
        "Part 01"
      ],
      "task_points": [],
      "solution_commands": [
        [
          "tuned-adm recommended",
          "tuned-adm profile <recommended-profile>",
          "tuned-adm active"
        ]
      ]
    }
  }
}
