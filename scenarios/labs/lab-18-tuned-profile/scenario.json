  "description": "Apply the system recommended tuned profile",
  "objective_tags": [
    "processes-logs-tuning"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 15,
  "vm_scripts": {
    "clientvm": "scripts/clientvm.sh"
  },
