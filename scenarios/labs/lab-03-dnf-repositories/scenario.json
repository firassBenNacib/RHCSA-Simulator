{
  "id": "lab-03-dnf-repositories",
  "title": "Lab 03: DNF Repository Configuration",
  "description": "Configure offline BaseOS and AppStream repositories on both systems",
  "objective_tags": [
    "software-scheduling-time"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 40,
  "vm_scripts": {
    "clientvm": "scripts/clientvm.sh",
    "servervm": "scripts/servervm.sh"
  },
  "flags": {
    "password_recovery": false,
    "requires_servervm": true
  },
  "content": {
    "lab": {
      "tasks": [
        "On clientvm, configure a persistent repository file with the following settings:\n\nBaseOS: http://servervm/repo/BaseOS/\nAppStream: http://servervm/repo/AppStream/\ngpgcheck: disabled\nRepositories: enabled",
        "On servervm, configure the same repository file with the same settings.",
        "Verify that both repositories are available on both systems."
      ],
      "hints": [
        "You can use one repo file per system.",
        "Use vim to type the repository file manually."
      ],
      "checks": [
        "dnf repolist",
        "ssh admin@servervm sudo dnf repolist"
      ],
      "solution_outline": [
        "Use persistent configuration only."
      ],
      "task_titles": [
        "Client Repositories",
        "Server Repositories",
        "Verify Repositories"
      ],
      "task_points": [],
      "solution_commands": [
        [
          "vim /etc/yum.repos.d/rhcsa.repo",
          "[rhcsa-baseos]",
          "name=RHCSA BaseOS",
          "baseurl=http://servervm/repo/BaseOS/",
          "enabled=1",
          "gpgcheck=0",
          "",
          "[rhcsa-appstream]",
          "name=RHCSA AppStream",
          "baseurl=http://servervm/repo/AppStream/",
          "enabled=1",
          "gpgcheck=0",
          ":wq",
          "dnf clean all"
        ],
        [
          "# Run on servervm",
          "vim /etc/yum.repos.d/rhcsa.repo",
          "[rhcsa-baseos]",
          "name=RHCSA BaseOS",
          "baseurl=http://servervm/repo/BaseOS/",
          "enabled=1",
          "gpgcheck=0",
          "",
          "[rhcsa-appstream]",
          "name=RHCSA AppStream",
          "baseurl=http://servervm/repo/AppStream/",
          "enabled=1",
          "gpgcheck=0",
          ":wq",
          "dnf clean all"
        ],
        [
          "dnf repolist",
          "# Run on servervm",
          "dnf repolist"
        ]
      ]
    }
  }
}
