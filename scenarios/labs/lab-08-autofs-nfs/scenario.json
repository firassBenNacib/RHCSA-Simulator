{
  "id": "lab-08-autofs-nfs",
  "title": "Lab 08: Autofs With NFS",
  "description": "Configure an indirect automount from servervm",
  "objective_tags": [
    "filesystems-and-autofs"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 40,
  "vm_scripts": {
    "clientvm": "scripts/clientvm.sh",
    "servervm": "scripts/servervm.sh"
  },
  "flags": {
    "password_recovery": false,
    "requires_servervm": true
  },
  "content": {
    "lab": {
      "tasks": [
        "On servervm, export /exports/vault8. On clientvm, create user vault8 with password cinder9.",
        "Configure autofs on clientvm so /netdir/vault8 is mounted on demand from servervm:/exports/vault8.",
        "Leave the configuration persistent across reboot."
      ],
      "hints": [
        "Use an indirect map.",
        "The export already contains a file named welcome.txt."
      ],
      "checks": [
        "showmount -e servervm | grep -Eq '(^|[[:space:]])/exports/vault8([[:space:]]|$)' && getent passwd vault8 >/dev/null && getent shadow vault8 | awk -F: 'length($2)>0 && $2 !~ /^(!!?|\\*|LK|NP)$/' >/dev/null",
        "mount | grep -Eq 'servervm:/exports/vault8 on /netdir/vault8 type nfs'",
        "test -f /netdir/vault8/welcome.txt && grep -Fqx 'autofs lab 08' /netdir/vault8/welcome.txt"
      ],
      "solution_outline": [
        "Use persistent configuration only."
      ],
      "task_titles": [
        "Seed Export And User",
        "Configure Autofs Map",
        "Verify Access"
      ],
      "task_points": [
        10,
        10,
        10
      ],
      "solution_commands": [
        [
          "# On servervm",
          "mkdir -p /exports/vault8",
          "printf \"autofs lab 08\\n\" > /exports/vault8/welcome.txt",
          "exportfs -arv",
          "# On clientvm",
          "useradd vault8",
          "passwd vault8",
          "# enter: cinder9"
        ],
        [
          "vim /etc/auto.lab8",
          "vault8 -rw,sync servervm:/exports/vault8",
          "vim /etc/auto.master.d/lab8.autofs",
          "/netdir /etc/auto.lab8",
          "systemctl enable --now autofs"
        ],
        [
          "ls -l /netdir/vault8",
          "cat /netdir/vault8/welcome.txt"
        ]
      ]
    }
  }
}
