{
  "id": "lab-18-tuned-profile",
  "title": "Lab 18: Tuned Recommended Profile",
  "description": "Apply the system recommended tuned profile",
  "objective_tags": [
    "processes-logs-tuning"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 15,
  "tracks": [
    "rhcsa9"
  ],
  "rhel_major": 9,
  "vm_scripts": {
    "client": "scripts/client.sh"
  },
  "flags": {
    "password_recovery": false,
    "requires_server": false
  },
  "content": {
    "lab": {
      "tasks": [
        "On client, apply the recommended tuned profile and leave it active after reboot."
      ],
      "hints": [
        "Use tuned-adm recommend to see the target profile."
      ],
      "checks": [
        "rec=\"$(tuned-adm recommend | awk 'NF{print $1; exit}')\"; test -n \"$rec\" && tuned-adm active | grep -Eq \"(^|[[:space:]:])${rec}($|[[:space:]])\""
      ],
      "solution_outline": [
        "Use persistent configuration only."
      ],
      "task_titles": [
        "Apply the recommended tuned profile and leave it..."
      ],
      "task_points": [
        10
      ],
      "solution_commands": [
        [
          "systemctl enable --now tuned",
          "tuned-adm recommend",
          "rec=\"$(tuned-adm recommend | awk 'NF{print $1; exit}')\"",
          "test -n \"$rec\"",
          "tuned-adm profile \"$rec\"",
          "tuned-adm active"
        ]
      ],
      "task_targets": [
        "client"
      ],
      "solution_targets": [
        "client"
      ],
      "check_targets": [
        "client"
      ]
    }
  },
  "scope": "client"
}
