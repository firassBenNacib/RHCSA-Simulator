{
  "id": "lab-13-grep-filter",
  "title": "Lab 13: Text Filtering with Grep",
  "description": "Extract matching lines from a seeded words file",
  "objective_tags": [
    "essential-tools"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 15,
  "tracks": [
    "rhcsa9"
  ],
  "rhel_major": 9,
  "vm_scripts": {
    "client": "scripts/client.sh"
  },
  "flags": {
    "password_recovery": false,
    "requires_server": false
  },
  "content": {
    "lab": {
      "tasks": [
        "On client, from /usr/share/dict/words, extract the lines containing ich and save the result to /root/lines."
      ],
      "hints": [
        "The words file for this lab is preseeded if it was not present before."
      ],
      "checks": [
        "test -s /root/lines && grep -q 'ich' /root/lines && awk 'index($0,\"ich\")==0{exit 1}' /root/lines"
      ],
      "solution_outline": [
        "Use persistent configuration only."
      ],
      "task_titles": [
        "Extract the ich matches into /root/lines"
      ],
      "task_points": [
        10
      ],
      "solution_commands": [
        [
          "grep \"ich\" /usr/share/dict/words > /root/lines"
        ]
      ],
      "task_targets": [
        "client"
      ],
      "solution_targets": [
        "client"
      ],
      "check_targets": [
        "client"
      ]
    }
  },
  "scope": "client"
}
