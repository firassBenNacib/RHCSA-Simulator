{
  "id": "lab-20-build-container-image",
  "title": "Lab 20: Build Container Image",
  "description": "Build and tag a local container image from a provided Containerfile",
  "objective_tags": [
    "containers"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 30,
  "tracks": [
    "rhcsa9"
  ],
  "rhel_major": 9,
  "vm_scripts": {
    "client": "scripts/client.sh"
  },
  "flags": {
    "password_recovery": false,
    "requires_server": false
  },
  "content": {
    "lab": {
      "tasks": [
        "As user builder20, build an image named localhost/text2pdf20:latest from /opt/rhcsa/workspaces/text2pdf20/Containerfile."
      ],
      "hints": [
        "The Containerfile is already present in the workspace.",
        "Use podman build."
      ],
      "checks": [
        "runuser -l builder20 -c 'podman image exists localhost/text2pdf20:latest'"
      ],
      "solution_outline": [
        "Use persistent configuration only."
      ],
      "task_titles": [
        "Build the text2pdf20 image as builder20"
      ],
      "task_points": [
        10
      ],
      "solution_commands": [
        [
          "su - builder20",
          "cd /opt/rhcsa/workspaces/text2pdf20",
          "podman build -t localhost/text2pdf20:latest .",
          "podman images",
          "exit"
        ]
      ]
    }
  }
}
