{
  "id": "lab-43-package-install-remove",
  "title": "Lab 43: Package Install and Remove",
  "description": "Install packages from the prepared local repositories and remove the one that is no longer needed",
  "objective_tags": [
    "software-scheduling-time"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 25,
  "tracks": [
    "rhcsa9"
  ],
  "rhel_major": 9,
  "vm_scripts": {
    "client": "scripts/client.sh",
    "server": "scripts/server.sh"
  },
  "flags": {
    "password_recovery": false,
    "requires_server": true
  },
  "content": {
    "lab": {
      "tasks": [
        "On client, use the prepared local repositories to install tree, then remove dos2unix so tree remains installed.",
        "On server, use the prepared local repositories to install lsof, then remove dos2unix so lsof remains installed."
      ],
      "hints": [
        "The repositories are already defined for this lab. Focus on package management on each named system."
      ],
      "checks": [
        "rpm -q tree >/dev/null && ! rpm -q dos2unix >/dev/null",
        "# server rpm -q lsof >/dev/null && ! rpm -q dos2unix >/dev/null"
      ],
      "solution_outline": [],
      "task_titles": [
        "Client Package Install and Remove",
        "Server Package Install and Remove"
      ],
      "task_points": [
        10,
        10
      ],
      "solution_commands": [
        [
          "dnf install -y tree dos2unix",
          "dnf remove -y dos2unix",
          "rpm -q tree"
        ],
        [
          "dnf install -y lsof dos2unix",
          "dnf remove -y dos2unix",
          "rpm -q lsof"
        ]
      ],
      "task_targets": [
        "client",
        "server"
      ],
      "solution_targets": [
        "client",
        "server"
      ],
      "check_targets": [
        "client",
        "server"
      ]
    }
  },
  "scope": "client-server"
}
