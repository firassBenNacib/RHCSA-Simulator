  "content": {
    "lab": {
      "tasks": [
        "On client, use the prepared local repositories on client to install tree, then remove dos2unix so tree remains installed."
      ],
      "hints": [
        "The repositories are already defined for this lab. Focus on package management."
      ],
      "checks": [
        "rpm -q tree >/dev/null && ! rpm -q dos2unix >/dev/null"
      ],
      "solution_outline": [],
      "task_titles": [
        "Install tree and remove dos2unix"
      ],
      "task_points": [
        20
      ],
      "solution_commands": [
        [
          "dnf install -y tree dos2unix",
          "dnf remove -y dos2unix",
          "rpm -q tree"
        ]
      ],
      "task_targets": [
        "client"
      ],
      "solution_targets": [
        "client"
      ],
      "check_targets": [
        "client"
      ]
    }
  },
  "scope": "client-server"
}
