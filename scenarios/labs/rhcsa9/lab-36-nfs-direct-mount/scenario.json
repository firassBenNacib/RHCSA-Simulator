{
  "id": "lab-36-nfs-direct-mount",
  "title": "Lab 36: Persistent NFS Direct Mount",
  "description": "Mount a remote NFS export persistently using /etc/fstab",
  "objective_tags": [
    "filesystems-and-autofs",
    "storage-lvm"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 25,
  "tracks": [
    "rhcsa9"
  ],
  "rhel_major": 9,
  "vm_scripts": {
    "client": "scripts/client.sh",
    "server": "scripts/server.sh"
  },
  "flags": {
    "password_recovery": false,
    "requires_server": true
  },
  "content": {
    "lab": {
      "tasks": [
        "On client, persistently mount the NFS export 192.168.122.3:/exports/direct36 on client at /mnt/direct36.",
        "On client, use the mount options ro,sync, mount it now, and ensure the file nfs36.txt can be read from the mount point."
      ],
      "hints": [
        "Use /etc/fstab for persistence.",
        "Do not use autofs for this task."
      ],
      "checks": [
        "grep -Fqx '192.168.122.3:/exports/direct36 /mnt/direct36 nfs ro,sync 0 0' /etc/fstab",
        "mountpoint -q /mnt/direct36 && test -f /mnt/direct36/nfs36.txt"
      ],
      "solution_outline": [
        "Configure a direct persistent NFS mount."
      ],
      "task_titles": [
        "Persistently mount the NFS export...",
        "Mount the NFS export and read the file"
      ],
      "task_points": [
        10,
        20
      ],
      "solution_commands": [
        [
          "mkdir -p /mnt/direct36",
          "vim /etc/fstab",
          "192.168.122.3:/exports/direct36 /mnt/direct36 nfs ro,sync 0 0"
        ],
        [
          "# On client",
          "dnf install -y nfs-utils",
          "systemctl enable --now nfs-client.target || true",
          "mount /mnt/direct36 || mount -a",
          "for attempt in 1 2 3 4 5; do mountpoint -q /mnt/direct36 && test -f /mnt/direct36/nfs36.txt && break; sleep 2; done",
          "ls /mnt/direct36"
        ]
      ],
      "task_targets": [
        "client",
        "client"
      ],
      "solution_targets": [
        "client",
        "client"
      ],
      "check_targets": [
        "client",
        "client"
      ]
    }
  },
  "scope": "client-server"
}
