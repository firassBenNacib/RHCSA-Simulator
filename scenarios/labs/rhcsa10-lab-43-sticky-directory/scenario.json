      ],
      "hints": [
        "Use chmod 3770 for setgid plus sticky.",
        "Use chgrp or chown to set the group."
      ],
      "checks": [
        "getent group share10 >/dev/null",
        "stat -c '%U:%G' /srv/share10 | grep -qx root:share10",
        "stat -c '%a' /srv/share10 | grep -qx 3770"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "Create group share10",
        "Create /srv/share10 owned by root:share10",
        "Set permissions so group members can write and only owners can delete th"
      ],
      "task_points": [
        10,
        10,
        10
      ],
      "solution_commands": [
        [
          "groupadd share10"
        ],
        [
          "mkdir -p /srv/share10",
          "chown root:share10 /srv/share10"
        ],
        [
          "chmod 3770 /srv/share10"
