{
  "id": "rhcsa10-lab-08-shell-script-args",
  "title": "RHCSA 10 Lab 08: Script Arguments",
  "description": "Create a shell script that processes command-line arguments",
  "objective_tags": [
    "shell-scripting"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 25,
  "tracks": [
    "rhcsa10"
  ],
  "rhel_major": 10,
  "flags": {
    "password_recovery": false,
    "requires_server": false
  },
  "content": {
    "lab": {
      "tasks": [
        "Create /usr/local/bin/rhcsa10-user-report.",
        "The script must print usage: rhcsa10-user-report USER when no argument is supplied.",
        "When a user name is supplied, print that user's primary group name."
      ],
      "hints": [
        "Use id -gn USER.",
        "Test for an empty first positional parameter."
      ],
      "checks": [
        "test -x /usr/local/bin/rhcsa10-user-report",
        "/usr/local/bin/rhcsa10-user-report 2>&1 | grep -qx 'usage: rhcsa10-user-report USER'",
        "/usr/local/bin/rhcsa10-user-report root | grep -qx root"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "Create /usr/local/bin/rhcsa10-user-report",
        "The script must print usage: rhcsa10-user-report USER when no argument i",
        "When a user name is supplied, print that user's primary group name"
      ],
      "task_points": [
        10,
        10,
        10
      ],
      "solution_commands": [
        [
          "cat > /usr/local/bin/rhcsa10-user-report <<'EOF'",
          "#!/bin/bash",
          "if [ -z \"${1:-}\" ]; then",
          "  echo 'usage: rhcsa10-user-report USER' >&2",
          "  exit 2",
          "fi",
          "id -gn \"$1\"",
          "EOF"
        ],
        [
          "chmod +x /usr/local/bin/rhcsa10-user-report"
        ],
        [
          "/usr/local/bin/rhcsa10-user-report root"
        ]
      ]
    }
  }
}
