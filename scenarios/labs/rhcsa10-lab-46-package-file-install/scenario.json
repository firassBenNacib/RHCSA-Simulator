{
  "id": "rhcsa10-lab-46-package-file-install",
  "title": "RHCSA 10 Lab 46: Local RPM Install",
  "description": "Install software from a local RPM file",
  "objective_tags": [
    "software-management"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 20,
  "tracks": [
    "rhcsa10"
  ],
  "rhel_major": 10,
  "flags": {
    "password_recovery": false,
    "requires_server": true
  },
  "content": {
    "lab": {
      "tasks": [
        "Find an RPM named tree under /var/www/html/repo or the mounted ISO.",
        "Install the local RPM file without enabling external repositories.",
        "Verify that tree is installed."
      ],
      "hints": [
        "Use find to locate tree*.rpm.",
        "Use dnf install /path/to/package.rpm."
      ],
      "checks": [
        "rpm -q tree >/dev/null",
        "command -v tree >/dev/null",
        "rpm -q tree >/dev/null"
      ],
      "solution_outline": [
        "Make the requested configuration persistent and verify it before finishing."
      ],
      "task_titles": [
        "Find an RPM named tree under /var/www/html/repo or the mounted ISO",
        "Install the local RPM file without enabling external repositories",
        "Verify that tree is installed"
      ],
      "task_points": [
        10,
        10,
        10
      ],
      "solution_commands": [
        [
          "rpm_path=$(find /var/www/html/repo /mnt/rhcsa-bootstrap-iso -name 'tree-*.rpm' 2>/dev/null | head -n1)",
          "test -n \"$rpm_path\""
        ],
        [
          "dnf install -y \"$rpm_path\""
        ],
        [
          "rpm -q tree"
        ]
      ]
    }
  }
}
