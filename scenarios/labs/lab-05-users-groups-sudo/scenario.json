{
  "id": "lab-05-users-groups-sudo",
  "title": "Lab 05: Users Groups And Sudo",
  "description": "Create local users, a delegated admin group, and passwordless privileged access",
  "objective_tags": [
    "users-sudo-ssh"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 40,
  "vm_scripts": {
    "clientvm": "scripts/clientvm.sh"
  },
  "flags": {
    "password_recovery": false,
    "requires_servervm": false
  },
  "content": {
    "lab": {
      "tasks": [
        "Create the group opsrune and the users brenor, lyessa, and quillan. Put brenor and lyessa in opsrune as a supplementary group. Sarahx must have /sbin/nologin and must not be in opsrune.",
        "Set the password of all three users to cinder9.",
        "Allow members of opsrune to run useradd through sudo, and allow brenor to run passwd for other users without a sudo password prompt."
      ],
      "hints": [
        "Use useradd and usermod only.",
        "Create sudo policy files under /etc/sudoers.d and validate them with visudo."
      ],
      "checks": [
        "id brenor",
        "id lyessa",
        "getent passwd quillan",
        "visudo -cf /etc/sudoers.d/opsrune",
        "visudo -cf /etc/sudoers.d/brenor-passwd"
      ],
      "solution_outline": [
        "Use persistent configuration only."
      ],
      "task_titles": [
        "Part 01",
        "Part 02",
        "Part 03"
      ],
      "task_points": [],
      "solution_commands": [
        [
          "groupadd opsrune",
          "useradd -m brenor",
          "useradd -m lyessa",
          "useradd -m -s /sbin/nologin quillan",
          "usermod -aG opsrune brenor",
          "usermod -aG opsrune lyessa"
        ],
        [
          "passwd brenor",
          "# enter: cinder9",
          "passwd lyessa",
          "# enter: cinder9",
          "passwd quillan",
          "# enter: cinder9"
        ],
        [
          "visudo -f /etc/sudoers.d/opsrune",
          "%opsrune ALL=(root) /usr/sbin/useradd",
          "visudo -f /etc/sudoers.d/brenor-passwd",
          "brenor ALL=(root) NOPASSWD: /usr/bin/passwd"
        ]
      ]
    }
  }
}
