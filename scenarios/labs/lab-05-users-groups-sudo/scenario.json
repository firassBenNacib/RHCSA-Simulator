{
  "id": "lab-05-users-groups-sudo",
  "title": "Lab 05: Users Groups And Sudo",
  "description": "Create local users, a delegated admin group, and passwordless privileged access",
  "objective_tags": [
    "users-sudo-ssh"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 40,
  "vm_scripts": {
    "clientvm": "scripts/clientvm.sh"
  },
  "flags": {
    "password_recovery": false,
    "requires_servervm": false
  },
  "content": {
    "lab": {
      "tasks": [
        "Create the group sysadmx and the users harryx, natashax, and sarahx. Put harryx and natashax in sysadmx as a supplementary group. Sarahx must have /sbin/nologin and must not be in sysadmx.",
        "Set the password of all three users to redhat.",
        "Allow members of sysadmx to run useradd through sudo, and allow harryx to run passwd for other users without a sudo password prompt."
      ],
      "hints": [
        "Use useradd and usermod only.",
        "Create sudo policy files under /etc/sudoers.d and validate them with visudo."
      ],
      "checks": [
        "id harryx",
        "id natashax",
        "getent passwd sarahx",
        "visudo -cf /etc/sudoers.d/sysadmx",
        "visudo -cf /etc/sudoers.d/harryx-passwd"
      ],
      "solution_outline": [
        "Use persistent configuration only."
      ],
      "task_titles": [
        "Part 01",
        "Part 02",
        "Part 03"
      ],
      "task_points": [],
      "solution_commands": [
        [
          "groupadd sysadmx",
          "useradd -m harryx",
          "useradd -m natashax",
          "useradd -m -s /sbin/nologin sarahx",
          "usermod -aG sysadmx harryx",
          "usermod -aG sysadmx natashax"
        ],
        [
          "passwd harryx",
          "# enter: redhat",
          "passwd natashax",
          "# enter: redhat",
          "passwd sarahx",
          "# enter: redhat"
        ],
        [
          "visudo -f /etc/sudoers.d/sysadmx",
          "%sysadmx ALL=(root) /usr/sbin/useradd",
          "visudo -f /etc/sudoers.d/harryx-passwd",
          "harryx ALL=(root) NOPASSWD: /usr/bin/passwd"
        ]
      ]
    }
  }
}
