{
  "id": "lab-30-links-hard-soft",
  "title": "Lab 30: Hard And Soft Links",
  "description": "Create and verify both a hard link and a symbolic link to the same source file",
  "objective_tags": [
    "essential-tools"
  ],
  "supported_modes": [
    "lab"
  ],
  "time_limit_minutes": 15,
  "vm_scripts": {
    "clientvm": "scripts/clientvm.sh"
  },
  "flags": {
    "password_recovery": false,
    "requires_servervm": false
  },
  "content": {
    "lab": {
      "tasks": [
        "Create the file /root/linksource30 containing the text link-test.",
        "Create the hard link /root/linkhard30 and the symbolic link /root/linksoft30 to /root/linksource30."
      ],
      "hints": [
        "Use ln for both tasks, with and without -s."
      ],
      "checks": [
        "ls -li /root/linksource30 /root/linkhard30 /root/linksoft30",
        "readlink -f /root/linksoft30"
      ],
      "solution_outline": [
        "Use persistent configuration only."
      ],
      "task_titles": [
        "Part 01",
        "Part 02"
      ],
      "task_points": [],
      "solution_commands": [
        [
          "printf 'link-test\n' > /root/linksource30"
        ],
        [
          "ln /root/linksource30 /root/linkhard30",
          "ln -s /root/linksource30 /root/linksoft30"
        ]
      ]
    }
  }
}
