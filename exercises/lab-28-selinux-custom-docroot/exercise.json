{
  "id": "lab-28-selinux-custom-docroot",
  "title": "Lab 28: SELinux Custom Document Root",
  "description": "Serve a custom document root on a nonstandard HTTP port while keeping SELinux enforcing.",
  "time_limit_minutes": 35,
  "objective_tags": [
    "selinux-and-default-perms",
    "networking-and-firewall"
  ],
  "requires_servervm": false,
  "source_manifest": "scenarios/labs/lab-28-selinux-custom-docroot/scenario.json",
  "paths": {
    "prompt": "exercises/lab-28-selinux-custom-docroot/prompt.md",
    "hint": "exercises/lab-28-selinux-custom-docroot/hint.md",
    "check": "exercises/lab-28-selinux-custom-docroot/check.sh",
    "solution": "exercises/lab-28-selinux-custom-docroot/solution.md",
    "metadata": "exercises/lab-28-selinux-custom-docroot/exercise.json"
  },
  "tasks": [
    {
      "index": 1,
      "title": "Configure Apache to serve content from",
      "points": 10,
      "system": "clientvm",
      "prompt": "Configure Apache to serve content from /srv/lab28/site on TCP port 8088.",
      "solution_commands": [
        "vim /etc/httpd/conf.d/lab28.conf",
        "<VirtualHost *:8088>",
        "    DocumentRoot /srv/lab28/site",
        "    <Directory /srv/lab28/site>",
        "        Require all granted",
        "    </Directory>",
        "</VirtualHost>"
      ]
    },
    {
      "index": 2,
      "title": "Keep SELinux enforcing, configure the correct file",
      "points": 10,
      "system": "clientvm",
      "prompt": "Keep SELinux enforcing, configure the correct file context and port label, open the firewall permanently, and enable the service at boot.",
      "solution_commands": [
        "semanage fcontext -a -t httpd_sys_content_t \"/srv/lab28/site(/.*)?\"",
        "restorecon -Rv /srv/lab28/site",
        "semanage port -a -t http_port_t -p tcp 8088",
        "firewall-cmd --permanent --add-port=8088/tcp",
        "firewall-cmd --reload",
        "systemctl enable --now httpd"
      ]
    },
    {
      "index": 3,
      "title": "Do not edit or remove /srv/lab28/site/index.html",
      "points": 10,
      "system": "clientvm",
      "prompt": "Do not edit or remove /srv/lab28/site/index.html.",
      "solution_commands": [
        "curl -s http://localhost:8088"
      ]
    }
  ],
  "hints": [
    "Create a dedicated configuration file in /etc/httpd/conf.d.",
    "Use semanage fcontext and semanage port."
  ],
  "checks": [
    {
      "index": 1,
      "target": "clientvm",
      "original_command": "curl -fsS http://localhost:8088 >/dev/null",
      "command": "curl -fsS http://localhost:8088 >/dev/null"
    },
    {
      "index": 2,
      "target": "clientvm",
      "original_command": "semanage port -l | grep -Eq '^http_port_t\\b.*\\b8088\\b' && firewall-cmd --permanent --query-port=8088/tcp && systemctl is-enabled httpd | grep -qx enabled",
      "command": "semanage port -l | grep -Eq '^http_port_t\\b.*\\b8088\\b' && firewall-cmd --permanent --query-port=8088/tcp && systemctl is-enabled httpd | grep -qx enabled"
    },
    {
      "index": 3,
      "target": "clientvm",
      "original_command": "matchpathcon /srv/lab28/site/index.html | grep -Eq ':httpd_sys_content_t:' && ls -Zd /srv/lab28/site | grep -Eq ':httpd_sys_content_t:'",
      "command": "matchpathcon /srv/lab28/site/index.html | grep -Eq ':httpd_sys_content_t:' && ls -Zd /srv/lab28/site | grep -Eq ':httpd_sys_content_t:'"
    }
  ]
}
