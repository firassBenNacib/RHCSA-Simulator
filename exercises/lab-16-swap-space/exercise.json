    "metadata": "exercises/lab-16-swap-space/exercise.json"
  },
  "tasks": [
    {
      "index": 1,
      "title": "Create a 400 MiB swap partition on /dev/sdb, enable",
      "points": 10,
      "system": "clientvm",
      "prompt": "Create a 400 MiB swap partition on /dev/sdb, enable it, and make it persistent.",
      "solution_commands": [
        "fdisk /dev/sdb",
        "# create a 400M partition and change the type to Linux swap",
        "partprobe /dev/sdb",
        "mkswap /dev/sdb1",
        "swapon /dev/sdb1",
        "blkid /dev/sdb1",
        "vim /etc/fstab",
        "UUID=<uuid-of-sdb1> swap swap defaults 0 0",
        "swapon --show"
      ]
    }
  ],
  "hints": [
    "Use GPT partition type 19 for swap.",
    "Use a UUID entry in /etc/fstab."
  ],
  "checks": [
    {
      "index": 1,
      "target": "clientvm",
      "original_command": "swapon --noheadings --show=NAME | grep -qx '/dev/sdb1'",
      "command": "swapon --noheadings --show=NAME | grep -qx '/dev/sdb1'"
    },
    {
      "index": 2,
      "target": "clientvm",
      "original_command": "blkid -o value -s TYPE /dev/sdb1 | grep -qx swap",
      "command": "blkid -o value -s TYPE /dev/sdb1 | grep -qx swap"
    },
    {
      "index": 3,
      "target": "clientvm",
      "original_command": "uuid=\"$(blkid -o value -s UUID /dev/sdb1)\"; grep -Eq \"^UUID=${uuid}[[:space:]]+swap[[:space:]]+swap[[:space:]]+\" /etc/fstab",
      "command": "uuid=\"$(blkid -o value -s UUID /dev/sdb1)\"; grep -Eq \"^UUID=${uuid}[[:space:]]+swap[[:space:]]+swap[[:space:]]+\" /etc/fstab"
    }
  ]
}
