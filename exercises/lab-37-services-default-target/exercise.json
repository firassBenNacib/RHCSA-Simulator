{
  "id": "lab-37-services-default-target",
  "title": "Lab 37: Services and Default Target",
  "description": "Control the default boot target and manage system services in a persistent way.",
  "time_limit_minutes": 20,
  "objective_tags": [
    "software-scheduling-time",
    "boot-and-recovery"
  ],
  "requires_servervm": false,
  "source_manifest": "scenarios/labs/lab-37-services-default-target/scenario.json",
  "paths": {
    "prompt": "exercises/lab-37-services-default-target/prompt.md",
    "hint": "exercises/lab-37-services-default-target/hint.md",
    "check": "exercises/lab-37-services-default-target/check.sh",
    "solution": "exercises/lab-37-services-default-target/solution.md",
    "metadata": "exercises/lab-37-services-default-target/exercise.json"
  },
  "tasks": [
    {
      "index": 1,
      "title": "Configure clientvm to boot into multi-user.target",
      "points": 10,
      "system": "clientvm",
      "prompt": "Configure clientvm to boot into multi-user.target by default.",
      "solution_commands": [
        "systemctl set-default multi-user.target"
      ]
    },
    {
      "index": 2,
      "title": "Ensure the rsyslog service is enabled and running",
      "points": 10,
      "system": "clientvm",
      "prompt": "Ensure the rsyslog service is enabled and running.",
      "solution_commands": [
        "systemctl enable --now rsyslog"
      ]
    },
    {
      "index": 3,
      "title": "If postfix is installed, disable it and stop it",
      "points": 10,
      "system": "clientvm",
      "prompt": "If postfix is installed, disable it and stop it.",
      "solution_commands": [
        "systemctl disable --now postfix"
      ]
    }
  ],
  "hints": [
    "Use systemctl for both target and service management."
  ],
  "checks": [
    {
      "index": 1,
      "target": "clientvm",
      "original_command": "systemctl get-default | grep -qx multi-user.target",
      "command": "systemctl get-default | grep -qx multi-user.target"
    },
    {
      "index": 2,
      "target": "clientvm",
      "original_command": "systemctl is-enabled rsyslog | grep -qx enabled",
      "command": "systemctl is-enabled rsyslog | grep -qx enabled"
    },
    {
      "index": 3,
      "target": "clientvm",
      "original_command": "systemctl is-active rsyslog | grep -qx active",
      "command": "systemctl is-active rsyslog | grep -qx active"
    }
  ]
}
