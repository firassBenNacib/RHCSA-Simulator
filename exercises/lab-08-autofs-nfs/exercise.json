{
  "id": "lab-08-autofs-nfs",
  "title": "Lab 08: Autofs With NFS",
  "description": "Configure an indirect automount from servervm.",
  "time_limit_minutes": 40,
  "objective_tags": [
    "filesystems-and-autofs"
  ],
  "requires_servervm": true,
  "source_manifest": "scenarios/labs/lab-08-autofs-nfs/scenario.json",
  "paths": {
    "prompt": "exercises/lab-08-autofs-nfs/prompt.md",
    "hint": "exercises/lab-08-autofs-nfs/hint.md",
    "check": "exercises/lab-08-autofs-nfs/check.sh",
    "solution": "exercises/lab-08-autofs-nfs/solution.md",
    "metadata": "exercises/lab-08-autofs-nfs/exercise.json"
  },
  "tasks": [
    {
      "index": 1,
      "title": "Seed Export And User",
      "points": 10,
      "system": "servervm",
      "prompt": "On servervm, export /exports/vault8. On clientvm, create user vault8 with password cinder9.",
      "solution_commands": [
        "# On servervm",
        "mkdir -p /exports/vault8",
        "printf \"autofs lab 08\\n\" > /exports/vault8/welcome.txt",
        "exportfs -arv",
        "# On clientvm",
        "useradd -m vault8",
        "passwd vault8",
        "# enter: cinder9"
      ]
    },
    {
      "index": 2,
      "title": "Configure Autofs Map",
      "points": 10,
      "system": "clientvm + servervm",
      "prompt": "Configure autofs on clientvm so /netdir/vault8 is mounted on demand from servervm:/exports/vault8.",
      "solution_commands": [
        "vim /etc/auto.lab8",
        "vault8 -rw,sync servervm:/exports/vault8",
        "vim /etc/auto.master.d/lab8.autofs",
        "/netdir /etc/auto.lab8",
        "systemctl enable --now autofs"
      ]
    },
    {
      "index": 3,
      "title": "Verify Access",
      "points": 10,
      "system": "clientvm",
      "prompt": "Leave the configuration persistent across reboot.",
      "solution_commands": [
        "ls -l /netdir/vault8",
        "cat /netdir/vault8/welcome.txt"
      ]
    }
  ],
  "hints": [
    "Use an indirect map.",
    "The export already contains a file named welcome.txt."
  ],
  "checks": [
    {
      "index": 1,
      "target": "clientvm",
      "original_command": "showmount -e servervm | grep -Eq '(^|[[:space:]])/exports/vault8([[:space:]]|$)'",
      "command": "showmount -e servervm | grep -Eq '(^|[[:space:]])/exports/vault8([[:space:]]|$)'"
    },
    {
      "index": 2,
      "target": "clientvm",
      "original_command": "mount | grep -Eq 'servervm:/exports/vault8 on /netdir/vault8 type nfs'",
      "command": "mount | grep -Eq 'servervm:/exports/vault8 on /netdir/vault8 type nfs'"
    },
    {
      "index": 3,
      "target": "clientvm",
      "original_command": "test -f /netdir/vault8/welcome.txt && grep -Fqx 'autofs lab 08' /netdir/vault8/welcome.txt",
      "command": "test -f /netdir/vault8/welcome.txt && grep -Fqx 'autofs lab 08' /netdir/vault8/welcome.txt"
    }
  ]
}
