{
  "id": "lab-31-shell-loop-script",
  "title": "Lab 31: Shell Loop Script",
  "description": "Create a simple shell script that uses a loop to filter files by name.",
  "time_limit_minutes": 25,
  "objective_tags": [
    "shell-scripting"
  ],
  "requires_servervm": false,
  "source_manifest": "scenarios/labs/lab-31-shell-loop-script/scenario.json",
  "paths": {
    "prompt": "exercises/lab-31-shell-loop-script/prompt.md",
    "hint": "exercises/lab-31-shell-loop-script/hint.md",
    "check": "exercises/lab-31-shell-loop-script/check.sh",
    "solution": "exercises/lab-31-shell-loop-script/solution.md",
    "metadata": "exercises/lab-31-shell-loop-script/exercise.json"
  },
  "tasks": [
    {
      "index": 1,
      "title": "Create an executable script",
      "points": 10,
      "system": "clientvm",
      "prompt": "Create an executable script /usr/local/bin/listlogs31 that loops over the files in /opt/lab31 and writes the absolute path of each file ending in .log to /root/listlogs31.out.",
      "solution_commands": [
        "vim /usr/local/bin/listlogs31",
        "#!/bin/bash",
        "for item in /opt/lab31/*; do",
        "    if [[ \"$item\" == *.log ]]; then",
        "        echo \"$item\" >> /root/listlogs31.out",
        "    fi",
        "done",
        "chmod +x /usr/local/bin/listlogs31"
      ]
    },
    {
      "index": 2,
      "title": "Run the script once",
      "points": 10,
      "system": "clientvm",
      "prompt": "Run the script once.",
      "solution_commands": [
        "/usr/local/bin/listlogs31"
      ]
    }
  ],
  "hints": [
    "A for loop is sufficient for this task.",
    "Write one path per line."
  ],
  "checks": [
    {
      "index": 1,
      "target": "clientvm",
      "original_command": "diff -u <(find /opt/lab31 -maxdepth 1 -type f -name '*.log' | sort) <(sort /root/listlogs31.out)",
      "command": "diff -u <(find /opt/lab31 -maxdepth 1 -type f -name '*.log' | sort) <(sort /root/listlogs31.out)"
    }
  ]
}
