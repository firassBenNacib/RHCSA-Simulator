{
  "id": "lab-05-users-groups-sudo",
  "title": "Lab 05: Users Groups And Sudo",
  "description": "Create local users, a delegated admin group, and passwordless privileged access.",
  "time_limit_minutes": 40,
  "objective_tags": [
    "users-sudo-ssh"
  ],
  "requires_servervm": false,
  "source_manifest": "scenarios/labs/lab-05-users-groups-sudo/scenario.json",
  "paths": {
    "prompt": "exercises/lab-05-users-groups-sudo/prompt.md",
    "hint": "exercises/lab-05-users-groups-sudo/hint.md",
    "check": "exercises/lab-05-users-groups-sudo/check.sh",
    "solution": "exercises/lab-05-users-groups-sudo/solution.md",
    "metadata": "exercises/lab-05-users-groups-sudo/exercise.json"
  },
  "tasks": [
    {
      "index": 1,
      "title": "Create the group opsrune and the users brenor,",
      "points": 10,
      "system": "clientvm",
      "prompt": "Create the group opsrune and the users brenor, lyessa, and quillan. Put brenor and lyessa in opsrune as a supplementary group. Sarahx must have /sbin/nologin and must not be in opsrune.",
      "solution_commands": [
        "groupadd opsrune",
        "useradd -m brenor",
        "useradd -m lyessa",
        "useradd -m -s /sbin/nologin quillan",
        "usermod -aG opsrune brenor",
        "usermod -aG opsrune lyessa"
      ]
    },
    {
      "index": 2,
      "title": "Set the password of all three users to cinder9",
      "points": 10,
      "system": "clientvm",
      "prompt": "Set the password of all three users to cinder9.",
      "solution_commands": [
        "passwd brenor",
        "# enter: cinder9",
        "passwd lyessa",
        "# enter: cinder9",
        "passwd quillan",
        "# enter: cinder9"
      ]
    },
    {
      "index": 3,
      "title": "Allow members of opsrune to run useradd through",
      "points": 10,
      "system": "clientvm",
      "prompt": "Allow members of opsrune to run useradd through sudo, and allow brenor to run passwd for other users without a sudo password prompt.",
      "solution_commands": [
        "visudo -f /etc/sudoers.d/opsrune",
        "%opsrune ALL=(root) /usr/sbin/useradd",
        "visudo -f /etc/sudoers.d/brenor-passwd",
        "brenor ALL=(root) NOPASSWD: /usr/bin/passwd"
      ]
    }
  ],
  "hints": [
    "Use useradd and usermod only.",
    "Create sudo policy files under /etc/sudoers.d and validate them with visudo."
  ],
  "checks": [
    {
      "index": 1,
      "target": "clientvm",
      "original_command": "id -nG brenor | tr ' ' '\\n' | grep -qx opsrune && getent passwd brenor >/dev/null",
      "command": "id -nG brenor | tr ' ' '\\n' | grep -qx opsrune && getent passwd brenor >/dev/null"
    },
    {
      "index": 2,
      "target": "clientvm",
      "original_command": "id -nG lyessa | tr ' ' '\\n' | grep -qx opsrune && getent passwd lyessa >/dev/null",
      "command": "id -nG lyessa | tr ' ' '\\n' | grep -qx opsrune && getent passwd lyessa >/dev/null"
    },
    {
      "index": 3,
      "target": "clientvm",
      "original_command": "getent passwd quillan | awk -F: '{exit !($7==\"/sbin/nologin\")}'",
      "command": "getent passwd quillan | awk -F: '{exit !($7==\"/sbin/nologin\")}'"
    },
    {
      "index": 4,
      "target": "clientvm",
      "original_command": "visudo -cf /etc/sudoers.d/opsrune >/dev/null && grep -Eq '^%opsrune[[:space:]]+ALL=\\(root\\)[[:space:]]+/usr/sbin/useradd[[:space:]]*$' /etc/sudoers.d/opsrune",
      "command": "visudo -cf /etc/sudoers.d/opsrune >/dev/null && grep -Eq '^%opsrune[[:space:]]+ALL=\\(root\\)[[:space:]]+/usr/sbin/useradd[[:space:]]*$' /etc/sudoers.d/opsrune"
    },
    {
      "index": 5,
      "target": "clientvm",
      "original_command": "visudo -cf /etc/sudoers.d/brenor-passwd >/dev/null && grep -Eq '^brenor[[:space:]]+ALL=\\(root\\)[[:space:]]+NOPASSWD:[[:space:]]+/usr/bin/passwd[[:space:]]*$' /etc/sudoers.d/brenor-passwd",
      "command": "visudo -cf /etc/sudoers.d/brenor-passwd >/dev/null && grep -Eq '^brenor[[:space:]]+ALL=\\(root\\)[[:space:]]+NOPASSWD:[[:space:]]+/usr/bin/passwd[[:space:]]*$' /etc/sudoers.d/brenor-passwd"
    }
  ]
}
