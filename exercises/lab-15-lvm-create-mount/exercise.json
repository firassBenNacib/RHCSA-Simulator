{
  "id": "lab-15-lvm-create-mount",
  "title": "Lab 15: LVM Creation And Mount",
  "description": "Create a new volume group and logical volume and mount it persistently.",
  "time_limit_minutes": 40,
  "objective_tags": [
    "storage-lvm"
  ],
  "requires_servervm": false,
  "source_manifest": "scenarios/labs/lab-15-lvm-create-mount/scenario.json",
  "paths": {
    "prompt": "exercises/lab-15-lvm-create-mount/prompt.md",
    "hint": "exercises/lab-15-lvm-create-mount/hint.md",
    "check": "exercises/lab-15-lvm-create-mount/check.sh",
    "solution": "exercises/lab-15-lvm-create-mount/solution.md",
    "metadata": "exercises/lab-15-lvm-create-mount/exercise.json"
  },
  "tasks": [
    {
      "index": 1,
      "title": "On /dev/sdb, create an LVM partition, then create",
      "points": 10,
      "system": "clientvm",
      "prompt": "On /dev/sdb, create an LVM partition, then create volume group wgroupx with physical extent size 8 MiB.",
      "solution_commands": [
        "fdisk /dev/sdb",
        "# create a GPT LVM partition for the remaining disk space",
        "partprobe /dev/sdb",
        "pvcreate /dev/sdb1",
        "vgcreate -s 8M wgroupx /dev/sdb1",
        "lvcreate -n wsharex -l 50 wgroupx"
      ]
    },
    {
      "index": 2,
      "title": "Create logical volume wsharex with 50 extents,",
      "points": 10,
      "system": "clientvm",
      "prompt": "Create logical volume wsharex with 50 extents, format it as ext4, and mount it persistently on /mnt/wsharex.",
      "solution_commands": [
        "mkfs.ext4 /dev/wgroupx/wsharex",
        "mkdir -p /mnt/wsharex",
        "blkid /dev/wgroupx/wsharex",
        "vim /etc/fstab",
        "UUID=<uuid-of-wsharex> /mnt/wsharex ext4 defaults 0 0",
        "mount -a",
        "findmnt /mnt/wsharex"
      ]
    }
  ],
  "hints": [
    "Use GPT on /dev/sdb.",
    "Use a UUID entry in /etc/fstab."
  ],
  "checks": [
    {
      "index": 1,
      "target": "clientvm",
      "original_command": "pvs --noheadings -o pv_name,vg_name | awk '$1==\"/dev/sdb1\" && $2==\"wgroupx\"{found=1} END{exit !found}'",
      "command": "pvs --noheadings -o pv_name,vg_name | awk '$1==\"/dev/sdb1\" && $2==\"wgroupx\"{found=1} END{exit !found}'"
    },
    {
      "index": 2,
      "target": "clientvm",
      "original_command": "vgs --noheadings -o vg_name,vg_extent_size --units m --nosuffix | awk '$1==\"wgroupx\" && int($2)==8{found=1} END{exit !found}'",
      "command": "vgs --noheadings -o vg_name,vg_extent_size --units m --nosuffix | awk '$1==\"wgroupx\" && int($2)==8{found=1} END{exit !found}'"
    },
    {
      "index": 3,
      "target": "clientvm",
      "original_command": "lvs --noheadings -o lv_name,vg_name,lv_size --units m --nosuffix | awk '$1==\"wsharex\" && $2==\"wgroupx\" && $3>=399 && $3<=401{found=1} END{exit !found}'",
      "command": "lvs --noheadings -o lv_name,vg_name,lv_size --units m --nosuffix | awk '$1==\"wsharex\" && $2==\"wgroupx\" && $3>=399 && $3<=401{found=1} END{exit !found}'"
    },
    {
      "index": 4,
      "target": "clientvm",
      "original_command": "blkid -o value -s TYPE /dev/wgroupx/wsharex | grep -qx ext4",
      "command": "blkid -o value -s TYPE /dev/wgroupx/wsharex | grep -qx ext4"
    },
    {
      "index": 5,
      "target": "clientvm",
      "original_command": "findmnt -no TARGET,SOURCE,FSTYPE /mnt/wsharex | grep -Eq '^/mnt/wsharex /dev/mapper/wgroupx-wsharex ext4$'",
      "command": "findmnt -no TARGET,SOURCE,FSTYPE /mnt/wsharex | grep -Eq '^/mnt/wsharex /dev/mapper/wgroupx-wsharex ext4$'"
    }
  ]
}
