{
  "id": "lab-30-links-hard-soft",
  "title": "Lab 30: Hard And Soft Links",
  "description": "Create and verify both a hard link and a symbolic link to the same source file.",
  "time_limit_minutes": 15,
  "objective_tags": [
    "essential-tools"
  ],
  "requires_servervm": false,
  "source_manifest": "scenarios/labs/lab-30-links-hard-soft/scenario.json",
  "paths": {
    "prompt": "exercises/lab-30-links-hard-soft/prompt.md",
    "hint": "exercises/lab-30-links-hard-soft/hint.md",
    "check": "exercises/lab-30-links-hard-soft/check.sh",
    "solution": "exercises/lab-30-links-hard-soft/solution.md",
    "metadata": "exercises/lab-30-links-hard-soft/exercise.json"
  },
  "tasks": [
    {
      "index": 1,
      "title": "Create the file /root/linksource30 containing the",
      "points": 10,
      "system": "clientvm",
      "prompt": "Create the file /root/linksource30 containing the text link-test.",
      "solution_commands": [
        "printf 'link-test\n' > /root/linksource30"
      ]
    },
    {
      "index": 2,
      "title": "Create the hard link /root/linkhard30 and the",
      "points": 10,
      "system": "clientvm",
      "prompt": "Create the hard link /root/linkhard30 and the symbolic link /root/linksoft30 to /root/linksource30.",
      "solution_commands": [
        "ln /root/linksource30 /root/linkhard30",
        "ln -s /root/linksource30 /root/linksoft30"
      ]
    }
  ],
  "hints": [
    "Use ln for both tasks, with and without -s."
  ],
  "checks": [
    {
      "index": 1,
      "target": "clientvm",
      "original_command": "test \"$(stat -c '%i' /root/linksource30)\" = \"$(stat -c '%i' /root/linkhard30)\" && test \"$(stat -c '%h' /root/linksource30)\" -ge 2",
      "command": "test \"$(stat -c '%i' /root/linksource30)\" = \"$(stat -c '%i' /root/linkhard30)\" && test \"$(stat -c '%h' /root/linksource30)\" -ge 2"
    },
    {
      "index": 2,
      "target": "clientvm",
      "original_command": "test \"$(readlink -f /root/linksoft30)\" = '/root/linksource30' && grep -Fqx 'link-test' /root/linksource30",
      "command": "test \"$(readlink -f /root/linksoft30)\" = '/root/linksource30' && grep -Fqx 'link-test' /root/linksource30"
    }
  ]
}
