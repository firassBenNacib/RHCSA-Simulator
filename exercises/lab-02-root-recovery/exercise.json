{
  "id": "lab-02-root-recovery",
  "title": "Lab 02: Root Password Recovery",
  "description": "Recover root access through the bootloader and restore normal access on clientvm.",
  "time_limit_minutes": 40,
  "objective_tags": [
    "boot-and-recovery"
  ],
  "requires_servervm": false,
  "source_manifest": "scenarios/labs/lab-02-root-recovery/scenario.json",
  "paths": {
    "prompt": "exercises/lab-02-root-recovery/prompt.md",
    "hint": "exercises/lab-02-root-recovery/hint.md",
    "check": "exercises/lab-02-root-recovery/check.sh",
    "solution": "exercises/lab-02-root-recovery/solution.md",
    "metadata": "exercises/lab-02-root-recovery/exercise.json"
  },
  "tasks": [
    {
      "index": 1,
      "title": "Recover root access on clientvm from the console",
      "points": 10,
      "system": "clientvm",
      "prompt": "Recover root access on clientvm from the console and set the root password to cinder9.",
      "solution_commands": [
        "# At the boot menu, edit the selected kernel entry.",
        "# Append rw init=/bin/bash to the linux line and boot with Ctrl+x.",
        "passwd root",
        "# enter: cinder9",
        "touch /.autorelabel",
        "exec /sbin/init"
      ]
    },
    {
      "index": 2,
      "title": "After the system boots normally, confirm that",
      "points": 10,
      "system": "clientvm",
      "prompt": "After the system boots normally, confirm that SELinux relabeling completed and root can log in again.",
      "solution_commands": [
        "getenforce",
        "ls -Z /root | head"
      ]
    },
    {
      "index": 3,
      "title": "Leave SSH password authentication working for root",
      "points": 10,
      "system": "clientvm",
      "prompt": "Leave SSH password authentication working for root and admin.",
      "solution_commands": [
        "vim /etc/ssh/sshd_config",
        "PasswordAuthentication yes",
        "PermitRootLogin yes",
        "systemctl restart sshd"
      ]
    }
  ],
  "hints": [
    "Use the boot menu edit path with rw init=/bin/bash.",
    "Remember to touch /.autorelabel before starting the normal init process."
  ],
  "checks": [
    {
      "index": 1,
      "target": "clientvm",
      "original_command": "getenforce | grep -qx Enforcing",
      "command": "getenforce | grep -qx Enforcing"
    },
    {
      "index": 2,
      "target": "clientvm",
      "original_command": "ls -Zd /root | grep -Eq '(^| )[^ ]+:object_r:admin_home_t:s0($| )'",
      "command": "ls -Zd /root | grep -Eq '(^| )[^ ]+:object_r:admin_home_t:s0($| )'"
    },
    {
      "index": 3,
      "target": "clientvm",
      "original_command": "grep -Eq '^[[:space:]]*PasswordAuthentication[[:space:]]+yes[[:space:]]*$' /etc/ssh/sshd_config && grep -Eq '^[[:space:]]*PermitRootLogin[[:space:]]+yes[[:space:]]*$' /etc/ssh/sshd_config",
      "command": "grep -Eq '^[[:space:]]*PasswordAuthentication[[:space:]]+yes[[:space:]]*$' /etc/ssh/sshd_config && grep -Eq '^[[:space:]]*PermitRootLogin[[:space:]]+yes[[:space:]]*$' /etc/ssh/sshd_config"
    }
  ]
}
