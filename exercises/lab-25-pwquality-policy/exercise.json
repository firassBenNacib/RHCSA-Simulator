{
  "id": "lab-25-pwquality-policy",
  "title": "Lab 25: Pwquality Policy",
  "description": "Configure a persistent local password quality policy without editing PAM service files.",
  "time_limit_minutes": 20,
  "objective_tags": [
    "users-sudo-ssh"
  ],
  "requires_servervm": false,
  "source_manifest": "scenarios/labs/lab-25-pwquality-policy/scenario.json",
  "paths": {
    "prompt": "exercises/lab-25-pwquality-policy/prompt.md",
    "hint": "exercises/lab-25-pwquality-policy/hint.md",
    "check": "exercises/lab-25-pwquality-policy/check.sh",
    "solution": "exercises/lab-25-pwquality-policy/solution.md",
    "metadata": "exercises/lab-25-pwquality-policy/exercise.json"
  },
  "tasks": [
    {
      "index": 1,
      "title": "Create a persistent password quality policy in",
      "points": 10,
      "system": "clientvm",
      "prompt": "Create a persistent password quality policy in /etc/security/pwquality.conf.d so that local passwords must meet the following requirements:\n\nMINIMUM LENGTH: 12\nMINIMUM CHARACTER CLASSES: 3",
      "solution_commands": [
        "mkdir -p /etc/security/pwquality.conf.d",
        "vim /etc/security/pwquality.conf.d/lab25.conf",
        "minlen = 12",
        "minclass = 3"
      ]
    },
    {
      "index": 2,
      "title": "Do not edit any PAM service file for this task",
      "points": 10,
      "system": "clientvm",
      "prompt": "Do not edit any PAM service file for this task.",
      "solution_commands": [
        "grep -R \"minlen\\|minclass\" /etc/security/pwquality.conf.d"
      ]
    }
  ],
  "hints": [
    "Use a dedicated drop-in file.",
    "Keep the configuration minimal."
  ],
  "checks": [
    {
      "index": 1,
      "target": "clientvm",
      "original_command": "grep -R -Eq '^[[:space:]]*minlen[[:space:]]*=[[:space:]]*12[[:space:]]*$' /etc/security/pwquality.conf.d && grep -R -Eq '^[[:space:]]*minclass[[:space:]]*=[[:space:]]*3[[:space:]]*$' /etc/security/pwquality.conf.d",
      "command": "grep -R -Eq '^[[:space:]]*minlen[[:space:]]*=[[:space:]]*12[[:space:]]*$' /etc/security/pwquality.conf.d && grep -R -Eq '^[[:space:]]*minclass[[:space:]]*=[[:space:]]*3[[:space:]]*$' /etc/security/pwquality.conf.d"
    }
  ]
}
