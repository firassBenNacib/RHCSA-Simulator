{
  "id": "lab-26-default-acl-shared-dir",
  "title": "Lab 26: Default ACL Shared Directory",
  "description": "Create a collaborative directory that combines setgid permissions with a default ACL.",
  "time_limit_minutes": 30,
  "objective_tags": [
    "filesystems-and-autofs",
    "selinux-and-default-perms"
  ],
  "requires_servervm": false,
  "source_manifest": "scenarios/labs/lab-26-default-acl-shared-dir/scenario.json",
  "paths": {
    "prompt": "exercises/lab-26-default-acl-shared-dir/prompt.md",
    "hint": "exercises/lab-26-default-acl-shared-dir/hint.md",
    "check": "exercises/lab-26-default-acl-shared-dir/check.sh",
    "solution": "exercises/lab-26-default-acl-shared-dir/solution.md",
    "metadata": "exercises/lab-26-default-acl-shared-dir/exercise.json"
  },
  "tasks": [
    {
      "index": 1,
      "title": "Create the group collab26 and the user probe26. Set",
      "points": 10,
      "system": "clientvm",
      "prompt": "Create the group collab26 and the user probe26. Set the password of probe26 to cinder9.",
      "solution_commands": [
        "groupadd collab26",
        "useradd -m probe26",
        "passwd probe26",
        "# enter: cinder9"
      ]
    },
    {
      "index": 2,
      "title": "Create the directory /shared/collab26 with owner",
      "points": 10,
      "system": "clientvm",
      "prompt": "Create the directory /shared/collab26 with owner root, group collab26, and permissions 2770.",
      "solution_commands": [
        "mkdir -p /shared/collab26",
        "chown root:collab26 /shared/collab26",
        "chmod 2770 /shared/collab26"
      ]
    },
    {
      "index": 3,
      "title": "Configure a default ACL so that user probe26",
      "points": 10,
      "system": "clientvm",
      "prompt": "Configure a default ACL so that user probe26 receives rwx permissions on new files and directories created under /shared/collab26.",
      "solution_commands": [
        "setfacl -m d:u:probe26:rwx /shared/collab26",
        "getfacl /shared/collab26"
      ]
    }
  ],
  "hints": [
    "Use getfacl to confirm the effective and default entries."
  ],
  "checks": [
    {
      "index": 1,
      "target": "clientvm",
      "original_command": "stat -c '%U:%G %a' /shared/collab26 | grep -qx 'root:collab26 2770' && getfacl -cp /shared/collab26 | grep -qx 'default:user:probe26:rwx'",
      "command": "stat -c '%U:%G %a' /shared/collab26 | grep -qx 'root:collab26 2770' && getfacl -cp /shared/collab26 | grep -qx 'default:user:probe26:rwx'"
    }
  ]
}
