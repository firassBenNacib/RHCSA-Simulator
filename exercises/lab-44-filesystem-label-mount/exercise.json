{
  "id": "lab-44-filesystem-label-mount",
  "title": "Lab 44: Filesystem By Label",
  "description": "Create a filesystem, label it, and mount it persistently by label.",
  "time_limit_minutes": 25,
  "objective_tags": [
    "storage-lvm"
  ],
  "requires_servervm": false,
  "source_manifest": "scenarios/labs/lab-44-filesystem-label-mount/scenario.json",
  "paths": {
    "prompt": "exercises/lab-44-filesystem-label-mount/prompt.md",
    "hint": "exercises/lab-44-filesystem-label-mount/hint.md",
    "check": "exercises/lab-44-filesystem-label-mount/check.sh",
    "solution": "exercises/lab-44-filesystem-label-mount/solution.md",
    "metadata": "exercises/lab-44-filesystem-label-mount/exercise.json"
  },
  "tasks": [
    {
      "index": 1,
      "title": "On /dev/sdb, create a GPT partition of 600 MiB for",
      "points": 10,
      "system": "clientvm",
      "prompt": "On /dev/sdb, create a GPT partition of 600 MiB for an ext4 filesystem.",
      "solution_commands": [
        "fdisk /dev/sdb",
        "# g",
        "# n",
        "# <Enter>",
        "# <Enter>",
        "# +600M",
        "# w"
      ]
    },
    {
      "index": 2,
      "title": "Format the new partition with the filesystem label",
      "points": 10,
      "system": "clientvm",
      "prompt": "Format the new partition with the filesystem label DATA44 and mount it at /data44.",
      "solution_commands": [
        "mkfs.ext4 -L DATA44 /dev/sdb1",
        "mkdir -p /data44"
      ]
    },
    {
      "index": 3,
      "title": "Configure the mount persistently in /etc/fstab by",
      "points": 10,
      "system": "clientvm",
      "prompt": "Configure the mount persistently in /etc/fstab by using LABEL=DATA44.",
      "solution_commands": [
        "vim /etc/fstab",
        "LABEL=DATA44 /data44 ext4 defaults 0 0",
        ":wq",
        "mount -a",
        "findmnt /data44"
      ]
    }
  ],
  "hints": [
    "Use blkid or lsblk -f to verify the label."
  ],
  "checks": [
    {
      "index": 1,
      "target": "clientvm",
      "original_command": "blkid -o value -s LABEL /dev/sdb1 | grep -qx DATA44",
      "command": "blkid -o value -s LABEL /dev/sdb1 | grep -qx DATA44"
    },
    {
      "index": 2,
      "target": "clientvm",
      "original_command": "findmnt -no TARGET,SOURCE /data44 | grep -Eq '^/data44 /dev/sdb1$|^/data44 /dev/mapper/.+$' && grep -Eq '^[^#]*LABEL=DATA44[[:space:]]+/data44[[:space:]]+ext4' /etc/fstab",
      "command": "findmnt -no TARGET,SOURCE /data44 | grep -Eq '^/data44 /dev/sdb1$|^/data44 /dev/mapper/.+$' && grep -Eq '^[^#]*LABEL=DATA44[[:space:]]+/data44[[:space:]]+ext4' /etc/fstab"
    }
  ]
}
