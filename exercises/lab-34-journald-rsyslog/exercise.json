{
  "id": "lab-34-journald-rsyslog",
  "title": "Lab 34: Journald Persistence and Rsyslog",
  "description": "Configure persistent journal storage and a custom rsyslog drop-in for authentication warnings.",
  "time_limit_minutes": 25,
  "objective_tags": [
    "processes-logs-tuning",
    "software-scheduling-time"
  ],
  "requires_servervm": false,
  "source_manifest": "scenarios/labs/lab-34-journald-rsyslog/scenario.json",
  "paths": {
    "prompt": "exercises/lab-34-journald-rsyslog/prompt.md",
    "hint": "exercises/lab-34-journald-rsyslog/hint.md",
    "check": "exercises/lab-34-journald-rsyslog/check.sh",
    "solution": "exercises/lab-34-journald-rsyslog/solution.md",
    "metadata": "exercises/lab-34-journald-rsyslog/exercise.json"
  },
  "tasks": [
    {
      "index": 1,
      "title": "Configure journald on clientvm so logs are stored",
      "points": 10,
      "system": "clientvm",
      "prompt": "Configure journald on clientvm so logs are stored persistently across reboots.",
      "solution_commands": [
        "mkdir -p /var/log/journal",
        "vim /etc/systemd/journald.conf",
        "# Set: Storage=persistent",
        ":wq",
        "systemctl restart systemd-journald"
      ]
    },
    {
      "index": 2,
      "title": "Create the drop-in file",
      "points": 10,
      "system": "clientvm",
      "prompt": "Create the drop-in file /etc/rsyslog.d/10-auth34.conf so authpriv messages with priority warning and higher are written to /var/log/auth34.log.",
      "solution_commands": [
        "vim /etc/rsyslog.d/10-auth34.conf",
        "authpriv.warning    /var/log/auth34.log",
        ":wq"
      ]
    },
    {
      "index": 3,
      "title": "Ensure the rsyslog service is active after your",
      "points": 10,
      "system": "clientvm",
      "prompt": "Ensure the rsyslog service is active after your changes.",
      "solution_commands": [
        "systemctl restart rsyslog",
        "systemctl enable rsyslog"
      ]
    }
  ],
  "hints": [
    "Persistent journald storage requires the correct directory.",
    "Reload or restart the affected logging services after you update their configuration."
  ],
  "checks": [
    {
      "index": 1,
      "target": "clientvm",
      "original_command": "test -d /var/log/journal && grep -Eq '^[[:space:]]*Storage[[:space:]]*=[[:space:]]*persistent[[:space:]]*$' /etc/systemd/journald.conf",
      "command": "test -d /var/log/journal && grep -Eq '^[[:space:]]*Storage[[:space:]]*=[[:space:]]*persistent[[:space:]]*$' /etc/systemd/journald.conf"
    },
    {
      "index": 2,
      "target": "clientvm",
      "original_command": "grep -Eq '^[[:space:]]*authpriv\\.warning[[:space:]]+/var/log/auth34\\.log[[:space:]]*$' /etc/rsyslog.d/10-auth34.conf",
      "command": "grep -Eq '^[[:space:]]*authpriv\\.warning[[:space:]]+/var/log/auth34\\.log[[:space:]]*$' /etc/rsyslog.d/10-auth34.conf"
    },
    {
      "index": 3,
      "target": "clientvm",
      "original_command": "systemctl is-active rsyslog | grep -qx active",
      "command": "systemctl is-active rsyslog | grep -qx active"
    }
  ]
}
