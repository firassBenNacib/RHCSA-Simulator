{
  "id": "lab-35-process-priority-tuned",
  "title": "Lab 35: Process Priority and Tuned",
  "description": "Tune the system with the requested profile and adjust process scheduling priority.",
  "time_limit_minutes": 25,
  "objective_tags": [
    "processes-logs-tuning"
  ],
  "requires_servervm": false,
  "source_manifest": "scenarios/labs/lab-35-process-priority-tuned/scenario.json",
  "paths": {
    "prompt": "exercises/lab-35-process-priority-tuned/prompt.md",
    "hint": "exercises/lab-35-process-priority-tuned/hint.md",
    "check": "exercises/lab-35-process-priority-tuned/check.sh",
    "solution": "exercises/lab-35-process-priority-tuned/solution.md",
    "metadata": "exercises/lab-35-process-priority-tuned/exercise.json"
  },
  "tasks": [
    {
      "index": 1,
      "title": "Install the tuned package if it is not already",
      "points": 10,
      "system": "clientvm",
      "prompt": "Install the tuned package if it is not already present and activate the tuned profile throughput-performance on clientvm.",
      "solution_commands": [
        "dnf install -y tuned",
        "systemctl enable --now tuned",
        "tuned-adm profile throughput-performance"
      ]
    },
    {
      "index": 2,
      "title": "Start the command sleep 3600 in the background and",
      "points": 10,
      "system": "clientvm",
      "prompt": "Start the command sleep 3600 in the background and save its PID in /root/sleep35.pid.",
      "solution_commands": [
        "sleep 3600 &",
        "echo $! > /root/sleep35.pid"
      ]
    },
    {
      "index": 3,
      "title": "Adjust the nice value of that process so it becomes 5",
      "points": 10,
      "system": "clientvm",
      "prompt": "Adjust the nice value of that process so it becomes 5.",
      "solution_commands": [
        "renice 5 -p \"$(cat /root/sleep35.pid)\""
      ]
    }
  ],
  "hints": [
    "Use a persistent tuned command.",
    "Use ps to verify the final nice value of the target process."
  ],
  "checks": [
    {
      "index": 1,
      "target": "clientvm",
      "original_command": "tuned-adm active | grep -q throughput-performance",
      "command": "tuned-adm active | grep -q throughput-performance"
    },
    {
      "index": 2,
      "target": "clientvm",
      "original_command": "test -f /root/sleep35.pid",
      "command": "test -f /root/sleep35.pid"
    },
    {
      "index": 3,
      "target": "clientvm",
      "original_command": "ps -o ni= -p \"$(cat /root/sleep35.pid)\" | tr -d \" \" | grep -qx 5",
      "command": "ps -o ni= -p \"$(cat /root/sleep35.pid)\" | tr -d \" \" | grep -qx 5"
    }
  ]
}
