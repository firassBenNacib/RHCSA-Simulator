{
  "id": "lab-20-build-container-image",
  "title": "Lab 20: Build Container Image",
  "description": "Build and tag a local container image from a provided Containerfile.",
  "time_limit_minutes": 30,
  "objective_tags": [
    "containers"
  ],
  "requires_servervm": false,
  "source_manifest": "scenarios/labs/lab-20-build-container-image/scenario.json",
  "paths": {
    "prompt": "exercises/lab-20-build-container-image/prompt.md",
    "hint": "exercises/lab-20-build-container-image/hint.md",
    "check": "exercises/lab-20-build-container-image/check.sh",
    "solution": "exercises/lab-20-build-container-image/solution.md",
    "metadata": "exercises/lab-20-build-container-image/exercise.json"
  },
  "tasks": [
    {
      "index": 1,
      "title": "build an image named localhost/text2pdf20:latest",
      "points": 10,
      "system": "clientvm",
      "prompt": "As user builder20, build an image named localhost/text2pdf20:latest from /opt/rhcsa/workspaces/text2pdf20/Containerfile.",
      "solution_commands": [
        "id builder20 || useradd -m builder20",
        "passwd builder20",
        "# enter: cinder9",
        "su - builder20",
        "cd /opt/rhcsa/workspaces/text2pdf20",
        "podman build -t localhost/text2pdf20:latest .",
        "podman images",
        "exit"
      ]
    },
    {
      "index": 2,
      "title": "Verify that the image exists locally for that user",
      "points": 10,
      "system": "clientvm",
      "prompt": "Verify that the image exists locally for that user.",
      "solution_commands": [
        "runuser -l builder20 -c \"podman images\""
      ]
    }
  ],
  "hints": [
    "The Containerfile is already present in the workspace.",
    "Use podman build."
  ],
  "checks": [
    {
      "index": 1,
      "target": "clientvm",
      "original_command": "runuser -l builder20 -c 'podman image exists localhost/text2pdf20:latest'",
      "command": "runuser -l builder20 -c 'podman image exists localhost/text2pdf20:latest'"
    }
  ]
}
