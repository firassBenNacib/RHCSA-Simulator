{
  "id": "lab-36-nfs-direct-mount",
  "title": "Lab 36: Persistent NFS Direct Mount",
  "description": "Mount a remote NFS export persistently using /etc/fstab.",
  "time_limit_minutes": 25,
  "objective_tags": [
    "filesystems-and-autofs",
    "storage-lvm"
  ],
  "requires_servervm": true,
  "source_manifest": "scenarios/labs/lab-36-nfs-direct-mount/scenario.json",
  "paths": {
    "prompt": "exercises/lab-36-nfs-direct-mount/prompt.md",
    "hint": "exercises/lab-36-nfs-direct-mount/hint.md",
    "check": "exercises/lab-36-nfs-direct-mount/check.sh",
    "solution": "exercises/lab-36-nfs-direct-mount/solution.md",
    "metadata": "exercises/lab-36-nfs-direct-mount/exercise.json"
  },
  "tasks": [
    {
      "index": 1,
      "title": "Persistently mount the NFS export",
      "points": 10,
      "system": "clientvm",
      "prompt": "Persistently mount the NFS export 192.168.122.3:/exports/direct36 on clientvm at /mnt/direct36.",
      "solution_commands": [
        "mkdir -p /mnt/direct36",
        "vim /etc/fstab",
        "192.168.122.3:/exports/direct36 /mnt/direct36 nfs ro,sync 0 0",
        ":wq"
      ]
    },
    {
      "index": 2,
      "title": "Use the mount options ro,sync",
      "points": 10,
      "system": "clientvm",
      "prompt": "Use the mount options ro,sync.",
      "solution_commands": [
        "mount -a"
      ]
    },
    {
      "index": 3,
      "title": "Ensure the mount is available after a reboot and",
      "points": 10,
      "system": "clientvm",
      "prompt": "Ensure the mount is available after a reboot and that the file nfs36.txt can be read from the mount point.",
      "solution_commands": [
        "ls /mnt/direct36"
      ]
    }
  ],
  "hints": [
    "Use /etc/fstab for persistence.",
    "Do not use autofs for this task."
  ],
  "checks": [
    {
      "index": 1,
      "target": "clientvm",
      "original_command": "grep -Eq '^[^#].*192\\.168\\.122\\.3:/exports/direct36[[:space:]]+/mnt/direct36[[:space:]]+nfs[[:space:]]+ro,sync' /etc/fstab",
      "command": "grep -Eq '^[^#].*192\\.168\\.122\\.3:/exports/direct36[[:space:]]+/mnt/direct36[[:space:]]+nfs[[:space:]]+ro,sync' /etc/fstab"
    },
    {
      "index": 2,
      "target": "clientvm",
      "original_command": "mountpoint -q /mnt/direct36",
      "command": "mountpoint -q /mnt/direct36"
    },
    {
      "index": 3,
      "target": "clientvm",
      "original_command": "test -f /mnt/direct36/nfs36.txt",
      "command": "test -f /mnt/direct36/nfs36.txt"
    }
  ]
}
