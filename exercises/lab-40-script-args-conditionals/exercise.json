{
  "id": "lab-40-script-args-conditionals",
  "title": "Lab 40: Script Arguments and Conditionals",
  "description": "Create a small shell script that processes arguments and returns the correct exit status.",
  "time_limit_minutes": 25,
  "objective_tags": [
    "shell-scripting",
    "users-sudo-ssh"
  ],
  "requires_servervm": false,
  "source_manifest": "scenarios/labs/lab-40-script-args-conditionals/scenario.json",
  "paths": {
    "prompt": "exercises/lab-40-script-args-conditionals/prompt.md",
    "hint": "exercises/lab-40-script-args-conditionals/hint.md",
    "check": "exercises/lab-40-script-args-conditionals/check.sh",
    "solution": "exercises/lab-40-script-args-conditionals/solution.md",
    "metadata": "exercises/lab-40-script-args-conditionals/exercise.json"
  },
  "tasks": [
    {
      "index": 1,
      "title": "Create the executable script",
      "points": 10,
      "system": "clientvm",
      "prompt": "Create the executable script /usr/local/bin/usercheck40 on clientvm.",
      "solution_commands": [
        "vim /usr/local/bin/usercheck40"
      ]
    },
    {
      "index": 2,
      "title": "The script must accept one username argument",
      "points": 10,
      "system": "clientvm",
      "prompt": "The script must accept one username argument.",
      "solution_commands": [
        "#!/bin/bash",
        "user_name=\"$1\""
      ]
    },
    {
      "index": 3,
      "title": "If the user exists, print EXISTS: username to",
      "points": 10,
      "system": "clientvm",
      "prompt": "If the user exists, print EXISTS: username to standard output and exit with status 0.",
      "solution_commands": [
        "if id \"$user_name\" >/dev/null 2>&1; then",
        "  echo \"EXISTS: $user_name\"",
        "  exit 0",
        "else",
        "  echo \"MISSING: $user_name\"",
        "  exit 1",
        "fi"
      ]
    },
    {
      "index": 4,
      "title": "If the user does not exist, print MISSING: username",
      "points": 10,
      "system": "clientvm",
      "prompt": "If the user does not exist, print MISSING: username to standard output and exit with status 1.",
      "solution_commands": [
        ":wq",
        "chmod 755 /usr/local/bin/usercheck40"
      ]
    }
  ],
  "hints": [
    "Use an if test against the passwd database or the id command.",
    "Make the script executable."
  ],
  "checks": [
    {
      "index": 1,
      "target": "clientvm",
      "original_command": "id script40 >/dev/null 2>&1",
      "command": "id script40 >/dev/null 2>&1"
    },
    {
      "index": 2,
      "target": "clientvm",
      "original_command": "/usr/local/bin/usercheck40 script40 | grep -qx 'EXISTS: script40'",
      "command": "/usr/local/bin/usercheck40 script40 | grep -qx 'EXISTS: script40'"
    },
    {
      "index": 3,
      "target": "clientvm",
      "original_command": "output=\"$(/usr/local/bin/usercheck40 nosuch40 2>/dev/null || true)\"; test \"$output\" = 'MISSING: nosuch40'",
      "command": "output=\"$(/usr/local/bin/usercheck40 nosuch40 2>/dev/null || true)\"; test \"$output\" = 'MISSING: nosuch40'"
    }
  ]
}
